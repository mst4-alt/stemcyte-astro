{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/astro/bin/astro.mjs", "dev"],
      "port": 4321
    },
    {
      "name": "panel2-v2",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "5500", "brochure-project/output"],
      "port": 5500
    },
    {
      "name": "demos",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),f=p.join('demos',q.url==='/'?'index.html':q.url);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':'text/html'});r.end(d)}})}).listen(process.env.PORT||8123,()=>console.log('listening'))"],
      "port": 8123,
      "autoPort": true
    }
  ]
}
