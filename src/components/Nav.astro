---
const pathname = Astro.url.pathname;
const isClinical = pathname.startsWith('/clinical');

const consumerLinks = [
  { label: 'The Science', href: '/the-science' },
  { label: 'Why StemCyte', href: '/why-stemcyte' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Patient Stories', href: '/patient-stories' },
  { label: 'Our Story', href: '/our-story' },
];

const clinicalLinks = [
  { label: 'Overview', href: '/clinical' },
  { label: 'REGENECYTE\u00AE', href: '/clinical/regenecyte' },
  { label: 'Clinical Trials', href: '/clinical/clinical-trials' },
  { label: 'Publications', href: '/clinical/publications' },
  { label: 'Manufacturing', href: '/clinical/manufacturing' },
];

const navLinks = isClinical ? clinicalLinks : consumerLinks;
const ctaText = isClinical ? 'Request Information' : 'Enroll now';
const ctaHref = isClinical ? '/clinical/contact' : '/pricing';
---

<nav class:list={['nav', 'at-top', { clinical: isClinical }]} id="nav">
  <a href={isClinical ? '/clinical/' : '/'} class="logo">
    <img src="/images/logos/white_stemcyte.webp" alt="StemCyte" class="logo-white" width="150" height="28" fetchpriority="low" />
    <img src="/images/logos/fullcolor_stemcyte.webp" alt="StemCyte" class="logo-color" width="150" height="28" fetchpriority="low" />
    <img src="/images/logos/black_stemcyte.webp" alt="StemCyte" class="logo-black" width="150" height="28" fetchpriority="low" />
  </a>
  <div class="links">
    {isClinical && <a href="/" class="back-link">&larr; stemcyte.com</a>}
    {isClinical && <span class="links-sep"></span>}
    {navLinks.map(({ label, href }) => (
      <a href={href} class={pathname === href || pathname.startsWith(href + '/') ? 'active' : ''}>
        {label}
      </a>
    ))}
    {isClinical && <span class="lane-badge">Clinical</span>}
  </div>
  <div class="rg">
    <a href={ctaHref} class="cta">{ctaText}</a>
  </div>
  <button class="hamburger" aria-label="Open menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<div class="sheet-scrim" id="sheet-scrim"></div>
<div class="sheet" id="sheet" class:list={[{ 'sheet-clinical': isClinical }]}>
  <div class="sheet-handle"></div>
  {isClinical && (
    <div class="sheet-back">
      <a href="/">&larr; Back to stemcyte.com</a>
    </div>
  )}
  <div class="sheet-links">
    {navLinks.map(({ label, href }) => (
      <a href={href} class={pathname === href || pathname.startsWith(href + '/') ? 'active' : ''}>
        {label}
      </a>
    ))}
  </div>
  <div class="sheet-cta">
    <a href={ctaHref}>{ctaText}</a>
  </div>
  {!isClinical && (
    <div class="sheet-hcp">
      <a href="/clinical/">For Healthcare Professionals &rarr;</a>
    </div>
  )}
</div>

<script>
  const nav = document.getElementById('nav');
  const hero = document.getElementById('hero');
  const hamburger = nav?.querySelector('.hamburger');
  const scrim = document.getElementById('sheet-scrim');
  const sheet = document.getElementById('sheet');

  // Scroll detection
  if (nav && hero) {
    if (hero.dataset.navTheme === 'dark') nav.classList.add('dark-hero');
    if (hero.dataset.navTheme === 'plum') nav.classList.add('plum-hero');
    function ckNav() {
      if (hero.getBoundingClientRect().bottom < 80) {
        nav.classList.remove('at-top');
        nav.classList.add('scrolled');
      } else {
        nav.classList.add('at-top');
        nav.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', ckNav);
    ckNav();
  } else if (nav && !hero) {
    nav.classList.remove('at-top');
    nav.classList.add('scrolled');
  }

  // Mobile menu
  function openMenu() {
    sheet?.classList.add('open');
    scrim?.classList.add('open');
    document.body.style.overflow = 'hidden';
    hamburger?.setAttribute('aria-label', 'Close menu');
    const spans = hamburger?.querySelectorAll('span');
    if (spans) {
      spans[0].style.transform = 'rotate(45deg) translate(2.5px, 2.5px)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'rotate(-45deg) translate(2.5px, -2.5px)';
    }
  }

  function closeMenu() {
    sheet?.classList.remove('open');
    scrim?.classList.remove('open');
    document.body.style.overflow = '';
    hamburger?.setAttribute('aria-label', 'Open menu');
    const spans = hamburger?.querySelectorAll('span');
    if (spans) {
      spans[0].style.transform = '';
      spans[1].style.opacity = '';
      spans[2].style.transform = '';
    }
  }

  hamburger?.addEventListener('click', () => {
    sheet?.classList.contains('open') ? closeMenu() : openMenu();
  });
  scrim?.addEventListener('click', closeMenu);
</script>
