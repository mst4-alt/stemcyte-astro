---
import BaseLayout from '../layouts/BaseLayout.astro';
import TextReveal from '../components/islands/TextReveal.jsx';
import Odometer from '../components/islands/Odometer.jsx';
import HorizontalDiseaseScroll from '../components/islands/HorizontalDiseaseScroll.jsx';
import ManifestoTimeline from '../components/islands/ManifestoTimeline.jsx';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "The Science of Cord Blood Stem Cells",
  "description": "Learn how cord blood stem cells treat 80+ diseases today and are being researched for hundreds more.",
  "url": "https://stemcyte.com/the-science",
  "specialty": "Hematology"
};
---

<BaseLayout title="The Science" schema={schema}>

<!-- Scroll Progress -->
<div class="v2-progress" id="v2ScrollProgress"></div>

<!-- ═══ 1. HERO — Scroll-Driven Text Reveal ═══ -->
<section class="v2-hero" id="hero">
  <div class="v2-hero-bg"></div>
  <div class="v2-hero-content">
    <div class="v2-hero-label">The Science</div>
    <TextReveal
      client:load
      text="Your baby is born with the power to save a life — including their own"
      tag="h1"
      className="v2-hero-h1"
    />
    <p class="v2-hero-sub">Your newborn's umbilical cord contains stem cells that treat over 80 diseases today and are being researched for hundreds more.</p>
  </div>
</section>

<!-- ═══ 2. CORD BLOOD INTRO ═══ -->
<section class="v2-intro v2-anim">
  <div class="v2-pill" style="border-color:rgba(59,109,196,0.15);">
    <span style="color:#6B9BED;">Cord Blood</span>
  </div>
  <h2 class="v2-intro-title">What are cord blood stem cells?</h2>
  <p class="v2-intro-sub">Think of stem cells as your body's starter kit. They're the original cells that every other cell in your body comes from.</p>
</section>

<!-- ═══ 3. CORD BLOOD — Pinned Cross-Fade ═══ -->
<section class="v2-pinned" id="v2PinnedCB">
  <div class="v2-pinned-track" style="height:400vh;">
    <div class="v2-pinned-frame">
      <div class="v2-pinned-progress">
        <div class="v2-pin-dot active" data-idx="0"></div>
        <div class="v2-pin-dot" data-idx="1"></div>
        <div class="v2-pin-dot" data-idx="2"></div>
        <div class="v2-pin-dot" data-idx="3"></div>
      </div>

      <div class="v2-pinned-step active" data-cb-step="0">
        <div class="v2-step-ghost" style="color:rgba(59,109,196,0.06);">01</div>
        <h2 style="color:#3B6DC4;">Your baby is born with them</h2>
        <p>The blood left in your baby's umbilical cord after birth is rich with <strong>stem cells</strong> — the same type used in bone marrow transplants for decades. They build your baby's entire blood and immune system.</p>
      </div>

      <div class="v2-pinned-step" data-cb-step="1">
        <div class="v2-step-ghost" style="color:rgba(108,26,85,0.06);">02</div>
        <h2 style="color:#6C1A55;">They can rebuild what's broken</h2>
        <p>Every red blood cell, white blood cell, and platelet traces back to these stem cells. When someone fights leukemia, sickle cell disease, or an immune deficiency, <strong>a transplant can regenerate their entire blood and immune system</strong>.</p>
      </div>

      <div class="v2-pinned-step" data-cb-step="2">
        <div class="v2-step-ghost" style="color:rgba(42,99,124,0.06);">03</div>
        <h2 style="color:#2A637C;">Younger, stronger, unexposed</h2>
        <p>Collected at the moment of birth, cord blood stem cells have had <strong>zero exposure to environmental toxins, illness, or aging</strong>. They're a biological snapshot of your child's health at its purest.</p>
      </div>

      <div class="v2-pinned-step" data-cb-step="3">
        <div class="v2-step-ghost" style="color:rgba(196,148,62,0.06);">04</div>
        <h2 style="color:#C4943E;">Protection for the whole family</h2>
        <p>A guaranteed <strong>perfect match for your baby</strong>, 75% chance for siblings, and because cord blood requires less strict HLA matching than bone marrow — parents and extended family too.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 4. DISEASES — Horizontal Scroll Cards ═══ -->
<section class="v2-disease-section">
  <div class="v2-disease-header">
    <div class="v2-pill" style="border-color:rgba(79,163,184,0.2);">
      <span style="color:#4FA3B8;">Cord Blood Treatments</span>
    </div>
    <div class="v2-disease-title">80+ diseases treated with cord blood</div>
  </div>
  <HorizontalDiseaseScroll client:visible />
</section>

<!-- ═══ 5a. CORD TISSUE INTRO ═══ -->
<section class="v2-intro v2-anim">
  <div class="v2-pill" style="border-color:rgba(42,99,124,0.2);">
    <span style="color:#4FA3B8;">Cord Tissue</span>
  </div>
  <h2 class="v2-intro-title">What are cord tissue stem cells?</h2>
  <p class="v2-intro-sub">Your umbilical cord contains a second type of stem cell — one that doesn't build blood, but repairs and rebuilds the body itself.</p>
</section>

<!-- ═══ 5b. CORD TISSUE — Pinned Cross-Fade ═══ -->
<section class="v2-pinned" id="v2PinnedCT">
  <div class="v2-pinned-track" style="height:400vh;">
    <div class="v2-pinned-frame">
      <div class="v2-pinned-progress">
        <div class="v2-pin-dot active" data-idx="0"></div>
        <div class="v2-pin-dot" data-idx="1"></div>
        <div class="v2-pin-dot" data-idx="2"></div>
        <div class="v2-pin-dot" data-idx="3"></div>
      </div>

      <div class="v2-pinned-step active" data-ct-step="0">
        <div class="v2-step-ghost" style="color:rgba(42,99,124,0.06);">05</div>
        <h2 style="color:#2A637C;">There's more than blood in the cord</h2>
        <p>The umbilical cord itself — the tissue — contains a different type of stem cell called <strong>mesenchymal stem cells (MSCs)</strong>. They live inside a jelly-like substance called Wharton's jelly.</p>
      </div>

      <div class="v2-pinned-step" data-ct-step="1">
        <div class="v2-step-ghost" style="color:rgba(42,99,124,0.06);">06</div>
        <h2 style="color:#2A637C;">They repair, not replace</h2>
        <p>Where cord blood rebuilds your blood and immune system, cord tissue MSCs repair <strong>structural tissue — muscle, bone, cartilage, skin, and organs</strong>. They're the body's construction crew.</p>
      </div>

      <div class="v2-pinned-step" data-ct-step="2">
        <div class="v2-step-ghost" style="color:rgba(79,163,184,0.06);">07</div>
        <h2 style="color:#4FA3B8;">That changes everything</h2>
        <p>A cell that can repair tissue means potential treatments for <strong>Alzheimer's, Parkinson's, spinal cord injuries, diabetes, arthritis</strong> — conditions that affect millions and currently have no cure. Over 500 clinical trials are underway worldwide.</p>
      </div>

      <div class="v2-pinned-step" data-ct-step="3">
        <div class="v2-step-ghost" style="color:rgba(42,99,124,0.06);">08</div>
        <h2 style="color:#2A637C;">No matching required</h2>
        <p>Unlike cord blood, MSCs <strong>don't require HLA matching</strong>. That means they could potentially be used by any family member — parents, siblings, even grandparents — without the compatibility barrier.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 6. MANIFESTO — SVG Line-Draw Timeline ═══ -->
<section class="v2-manifesto">
  <div class="v2-manifesto-header">
    <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#4FA3B8;margin-bottom:12px;">Cord Tissue Research</div>
    <div style="font-family:'Playfair Display',serif;font-size:44px;font-weight:400;line-height:1.2;color:#fff;">Ten reasons cord tissue<br>is the future of medicine.</div>
    <div style="font-size:15px;color:rgba(255,255,255,0.3);max-width:440px;margin:16px auto 0;">One collection. One moment. A lifetime of possibilities that science is just beginning to unlock.</div>
  </div>

  <ManifestoTimeline client:visible />

  <div class="v2-stat-area">
    <Odometer
      client:visible
      value={500}
      suffix="+"
      color="#4FA3B8"
      digitHeight={56}
      label="active MSC clinical trials worldwide"
    />
  </div>

  <div style="text-align:center;margin-top:28px;">
    <a href="/biologics/clinical-trials" class="v2-cta-link v2-magnetic">View StemCyte clinical trials <span style="font-size:16px;">&#8594;</span></a>
  </div>
</section>

<!-- ═══ 7. CTA BANNER ═══ -->
<section class="v2-cta-banner">
  <h2>What happens if you don't <em>bank?</em></h2>
  <p>If your baby's cord blood is not collected at birth, it's discarded as medical waste. There is no way to go back.</p>
  <div class="v2-cta-btns">
    <a href="/pricing" class="v2-btn-solid v2-magnetic">View plans &amp; pricing</a>
    <a href="tel:8663894659" class="v2-btn-outline v2-magnetic">Call (866) 389-4659</a>
  </div>
</section>

<!-- ═══ VANILLA JS — Scroll progress, Pinned sections, Magnetic buttons, Reveal ═══ -->
<script is:inline>
(function() {
  var RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Scroll Progress ──
  var bar = document.getElementById('v2ScrollProgress');
  if (bar) {
    window.addEventListener('scroll', function() {
      requestAnimationFrame(function() {
        var h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.transform = 'scaleX(' + (window.scrollY / h) + ')';
      });
    }, { passive: true });
  }

  // ── Scroll Reveal for .v2-anim ──
  if (!RM) {
    var animObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('v2-vis'); animObs.unobserve(e.target); }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.v2-anim').forEach(function(el) { animObs.observe(el); });
  } else {
    document.querySelectorAll('.v2-anim').forEach(function(el) { el.classList.add('v2-vis'); });
  }

  // ── Pinned Cross-Fade Sections ──
  function initPinned(sectionId, stepAttr) {
    var section = document.getElementById(sectionId);
    if (!section) return;
    var track = section.querySelector('.v2-pinned-track');
    var steps = section.querySelectorAll('.v2-pinned-step');
    var dots = section.querySelectorAll('.v2-pin-dot');
    var count = steps.length;
    if (!count) return;

    if (RM || window.innerWidth < 900) {
      // Stack vertically
      steps.forEach(function(s) { s.classList.add('active'); });
      return;
    }

    var raf = null;
    window.addEventListener('scroll', function() {
      if (raf) return;
      raf = requestAnimationFrame(function() {
        raf = null;
        var rect = track.getBoundingClientRect();
        var scrolled = -rect.top;
        var scrollable = rect.offsetHeight || track.offsetHeight;
        var total = scrollable - window.innerHeight;
        if (total <= 0) return;
        var progress = Math.max(0, Math.min(0.999, scrolled / total));
        var idx = Math.floor(progress * count);

        steps.forEach(function(s, i) {
          if (i === idx) s.classList.add('active');
          else s.classList.remove('active');
        });
        dots.forEach(function(d, i) {
          if (i === idx) d.classList.add('active');
          else d.classList.remove('active');
        });
      });
    }, { passive: true });
  }

  initPinned('v2PinnedCB', 'data-cb-step');
  initPinned('v2PinnedCT', 'data-ct-step');

  // ── Magnetic Buttons ──
  if (!RM && !('ontouchstart' in window)) {
    document.querySelectorAll('.v2-magnetic').forEach(function(btn) {
      btn.addEventListener('mousemove', function(e) {
        var rect = btn.getBoundingClientRect();
        var cx = rect.left + rect.width / 2;
        var cy = rect.top + rect.height / 2;
        var dx = e.clientX - cx;
        var dy = e.clientY - cy;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 120) {
          var pull = (1 - dist / 120) * 0.25;
          btn.style.transform = 'translate(' + (dx * pull).toFixed(1) + 'px,' + (dy * pull).toFixed(1) + 'px)';
          btn.style.transition = 'transform 0.15s ease-out';
        }
      });
      btn.addEventListener('mouseleave', function() {
        btn.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
        btn.style.transform = '';
      });
    });
  }
})();
</script>

<style>
/* ═══ V2 SCOPED STYLES ═══ */

/* Progress bar */
.v2-progress {
  position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 9999;
  background: linear-gradient(90deg, #2A637C, #4FA3B8, #3B6DC4);
  transform: scaleX(0); transform-origin: left; will-change: transform;
}

/* Hero */
.v2-hero {
  position: relative; min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  background: #081518; overflow: hidden;
}
.v2-hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(42,99,124,0.15) 0%, transparent 70%);
}
.v2-hero-content {
  position: relative; z-index: 2;
  max-width: 900px; text-align: center; padding: 0 48px;
}
.v2-hero-label {
  font-size: 11px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: #4FA3B8; margin-bottom: 16px;
}
.v2-hero-h1 {
  font-family: 'Playfair Display', serif;
  font-size: 56px; font-weight: 400; line-height: 1.15;
  letter-spacing: -1.5px; color: #fff; margin-bottom: 24px;
}
.v2-hero-sub {
  font-size: 17px; color: rgba(255,255,255,0.4);
  max-width: 520px; margin: 0 auto; line-height: 1.7;
  opacity: 0; animation: v2FadeUp 0.8s 1.2s forwards;
}
@keyframes v2FadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Intro sections */
.v2-intro {
  text-align: center; padding: 100px 48px; background: #FAF7F2;
}
.v2-anim {
  opacity: 0; transform: translateY(32px);
  transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
}
.v2-anim.v2-vis { opacity: 1; transform: translateY(0); }
.v2-pill {
  display: inline-block; padding: 4px 14px; border-radius: 100px;
  border: 1px solid; margin-bottom: 12px;
}
.v2-pill span {
  font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
}
.v2-intro-title {
  font-family: 'Playfair Display', serif;
  font-size: 38px; font-weight: 400; color: #2C2A26; margin-bottom: 12px;
}
.v2-intro-sub {
  font-size: 15px; color: #6B665D; max-width: 480px;
  margin: 0 auto; line-height: 1.7;
}

/* Pinned sections */
.v2-pinned { background: #FAF7F2; }
.v2-pinned-track { position: relative; }
.v2-pinned-frame {
  position: sticky; top: 0; height: 100vh;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.v2-pinned-step {
  position: absolute; text-align: center;
  max-width: 620px; padding: 0 48px;
  opacity: 0; transform: translateY(28px);
  transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  pointer-events: none;
}
.v2-pinned-step.active {
  opacity: 1; transform: translateY(0); pointer-events: auto;
}
.v2-pinned-step h2 {
  font-family: 'Playfair Display', serif;
  font-size: 36px; font-weight: 400; line-height: 1.2; margin-bottom: 16px;
}
.v2-pinned-step p {
  font-size: 16px; color: #6B665D; line-height: 1.8; max-width: 520px; margin: 0 auto;
}
.v2-pinned-step p strong { color: #2C2A26; }
.v2-step-ghost {
  font-family: 'Source Serif 4', serif;
  font-size: 200px; font-weight: 400; line-height: 1;
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -55%);
  pointer-events: none; z-index: 0;
}
.v2-pinned-progress {
  position: absolute; right: 48px; top: 50%;
  transform: translateY(-50%);
  display: flex; flex-direction: column; gap: 14px; z-index: 5;
}
.v2-pin-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: rgba(0,0,0,0.08); transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
}
.v2-pin-dot.active {
  background: #2A637C; transform: scale(1.6);
  box-shadow: 0 0 12px rgba(42,99,124,0.3);
}

/* Disease section */
.v2-disease-section {
  background: radial-gradient(ellipse 70% 60% at 50% 45%, #1A3F50 0%, #0F2B35 40%, #081518 100%);
  padding: 100px 48px 40px; overflow: hidden;
}
.v2-disease-header { text-align: center; margin-bottom: 48px; }
.v2-disease-title {
  font-family: 'Playfair Display', serif;
  font-size: 38px; font-weight: 400; color: #fff; margin-top: 12px;
}

/* Manifesto */
.v2-manifesto {
  background: #0F2B35; padding: 100px 48px 80px; color: #fff;
}
.v2-manifesto-header { text-align: center; margin-bottom: 72px; }
.v2-stat-area { text-align: center; margin-top: 56px; }
.v2-cta-link {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 13px; font-weight: 700;
  color: rgba(79,163,184,0.5); text-decoration: none;
  padding: 10px 24px; border: 1px solid rgba(79,163,184,0.15);
  border-radius: 100px; transition: all 0.3s;
}
.v2-cta-link:hover {
  color: #4FA3B8; border-color: rgba(79,163,184,0.35);
  background: rgba(79,163,184,0.05);
}

/* CTA Banner */
.v2-cta-banner {
  margin: 80px 48px; border-radius: 16px;
  background: linear-gradient(160deg, #2A637C, #1A3F50);
  padding: 80px 64px; text-align: center;
  position: relative; overflow: hidden;
}
.v2-cta-banner::before {
  content: ''; position: absolute;
  width: 500px; height: 500px; border-radius: 50%;
  background: rgba(79,163,184,0.08); top: -200px; right: -100px;
}
.v2-cta-banner h2 {
  font-family: 'Playfair Display', serif;
  font-size: 36px; color: #fff; margin-bottom: 12px; position: relative;
}
.v2-cta-banner h2 em { font-style: italic; color: #4FA3B8; }
.v2-cta-banner p {
  font-size: 16px; color: rgba(255,255,255,0.65);
  margin-bottom: 32px; position: relative;
}
.v2-cta-btns {
  display: flex; gap: 12px; justify-content: center; position: relative;
}
.v2-btn-solid {
  background: #fff; color: #2A637C;
  padding: 16px 36px; border-radius: 100px;
  font-size: 15px; font-weight: 700; border: none;
  cursor: pointer; font-family: 'Lato', sans-serif;
  transition: background 0.25s; display: inline-block; text-decoration: none;
}
.v2-btn-solid:hover { background: rgba(255,255,255,0.85); }
.v2-btn-outline {
  background: transparent; color: #fff;
  padding: 16px 36px; border-radius: 100px;
  font-size: 15px; font-weight: 700;
  border: 1px solid rgba(255,255,255,0.25);
  cursor: pointer; font-family: 'Lato', sans-serif;
  transition: all 0.25s; display: inline-block; text-decoration: none;
}
.v2-btn-outline:hover {
  background: rgba(255,255,255,0.2);
  border-color: rgba(255,255,255,0.35);
}

/* ═══ RESPONSIVE ═══ */
@media (max-width: 900px) {
  .v2-hero-content { padding: 0 24px; }
  .v2-hero-h1 { font-size: 34px !important; }
  .v2-intro { padding: 60px 24px; }
  .v2-intro-title { font-size: 28px; }
  .v2-disease-section { padding: 60px 24px 40px; }
  .v2-disease-title { font-size: 28px; }
  .v2-manifesto { padding: 80px 24px; }
  .v2-manifesto-header div[style*="font-size:44px"] { font-size: 28px !important; }
  .v2-cta-banner { margin: 48px 20px; padding: 48px 24px; }

  /* Pinned → stacked */
  .v2-pinned-track { height: auto !important; }
  .v2-pinned-frame {
    position: relative; height: auto;
    flex-direction: column; padding: 40px 24px;
  }
  .v2-pinned-step {
    position: relative !important;
    opacity: 1 !important;
    transform: none !important;
    pointer-events: auto !important;
    padding: 32px 0;
    text-align: left;
  }
  .v2-pinned-step h2 { font-size: 26px; }
  .v2-step-ghost { display: none; }
  .v2-pinned-progress { display: none; }
}

@media (max-width: 600px) {
  .v2-cta-btns { flex-direction: column; align-items: center; }
}

@media (max-width: 480px) {
  .v2-hero-h1 { font-size: 28px !important; }
  .v2-intro-title { font-size: 24px; }
}

/* ═══ REDUCED MOTION ═══ */
@media (prefers-reduced-motion: reduce) {
  .v2-progress { display: none; }
  .v2-anim { opacity: 1 !important; transform: none !important; transition: none !important; }
  .v2-hero-sub { opacity: 1 !important; animation: none !important; }
  .v2-pinned-track { height: auto !important; }
  .v2-pinned-frame { position: relative; height: auto; flex-direction: column; padding: 40px 48px; }
  .v2-pinned-step {
    position: relative !important; opacity: 1 !important;
    transform: none !important; pointer-events: auto !important;
    padding: 32px 0;
  }
  .v2-step-ghost { display: none; }
  .v2-pinned-progress { display: none; }
}

/* Footer override */
.footer { background: #0F2B35 !important; }
.footer .col a:hover { color: #7CCADB !important; }
</style>

</BaseLayout>
