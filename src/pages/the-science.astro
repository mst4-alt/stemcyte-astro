<script is:inline>
// ═══ SCROLL PROGRESS ═══
window.addEventListener('scroll',()=>{const h=document.documentElement.scrollHeight-window.innerHeight;document.getElementById('scrollProgress').style.width=(window.scrollY/h)*100+'%';});

// ═══ SCROLL REVEAL (section titles) ═══
const srObs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){const d=parseInt(e.target.dataset.d||0);setTimeout(()=>e.target.classList.add('vis'),d);srObs.unobserve(e.target);}});},{threshold:0.3});
document.querySelectorAll('.sr').forEach(el=>srObs.observe(el));

// ═══ SECTION ENTRANCE (smooth fade-in for whole sections) ═══
const secObs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');secObs.unobserve(e.target);}});},{threshold:0.08});
document.querySelectorAll('.section-enter').forEach(el=>secObs.observe(el));

// ═══ STRIPE-STYLE PERF: pause offscreen, respect reduced motion ═══
const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
const lowPower = navigator.hardwareConcurrency ? navigator.hardwareConcurrency <= 2 : false;
const safeDPR = lowPower ? 1 : Math.min(devicePixelRatio || 1, 2);

function animateWhenVisible(canvasId, initFn) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const section = canvas.closest('section') || canvas.closest('.hero') || canvas.parentElement;
  let raf = null;
  let playing = false;
  const drawFn = initFn();

  // Expose draw function so scroll-step observers can trigger redraws in static mode
  canvas._drawFn = drawFn;

  if (reduceMotion) {
    // Draw one static frame; step observers will call canvas._drawFn on changes
    drawFn();
    return;
  }

  function play() {
    if (playing) return;
    playing = true;
    function tick() {
      drawFn();
      if (playing) raf = requestAnimationFrame(tick);
    }
    tick();
  }

  function pause() {
    playing = false;
    if (raf) { cancelAnimationFrame(raf); raf = null; }
  }

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) play();
      else pause();
    });
  }, { rootMargin: '100px 0px' });

  obs.observe(section);

  // If the element is already in viewport, start immediately
  if (section.getBoundingClientRect().top < window.innerHeight) {
    play();
  }
}

// ═══ HERO — Osmos Variant B "Soft Focus" ═══
animateWhenVisible('heroCanvas', () => {
  const palWarm=[{r:232,g:160,b:208},{r:192,g:96,b:160},{r:108,g:26,b:85},{r:160,g:80,b:140},{r:200,g:140,b:180},{r:180,g:130,b:190},{r:220,g:160,b:195},{r:170,g:100,b:150}];

  function heroSetup(){
    const canvas=document.getElementById('heroCanvas');const vp=canvas.parentElement;
    const ctx=canvas.getContext('2d');const dpr=safeDPR;
    let W=vp.offsetWidth,H=vp.offsetHeight;canvas.width=W*dpr;canvas.height=H*dpr;
    canvas.style.cssText='position:absolute;inset:0;width:100%;height:100%;display:block;z-index:1;';
    ctx.setTransform(dpr,0,0,dpr,0,0);
    let mx=-9999,my=-9999;
    vp.addEventListener('mousemove',e=>{const r=vp.getBoundingClientRect();mx=e.clientX-r.left;my=e.clientY-r.top;});
    vp.addEventListener('mouseleave',()=>{mx=-9999;my=-9999;});
    vp.addEventListener('touchmove',e=>{const touch=e.touches[0];const r=vp.getBoundingClientRect();mx=touch.clientX-r.left;my=touch.clientY-r.top;});
    vp.addEventListener('touchend',()=>{mx=-9999;my=-9999;});
    window.addEventListener('resize',()=>{W=vp.offsetWidth;H=vp.offsetHeight;canvas.width=W*dpr;canvas.height=H*dpr;ctx.setTransform(dpr,0,0,dpr,0,0);});
    return{ctx,gW:()=>vp.offsetWidth,gH:()=>vp.offsetHeight,gM:()=>({x:mx,y:my})};
  }

  function drawCell(ctx,x,y,r,col,opacity,blur){
    const bm=blur||1;
    const glowR=r*(1.2+bm*0.4);
    const og=ctx.createRadialGradient(x,y,r*0.3,x,y,glowR);
    og.addColorStop(0,`rgba(${col.r},${col.g},${col.b},${opacity*0.4*bm})`);
    og.addColorStop(0.5,`rgba(${col.r},${col.g},${col.b},${opacity*0.15*bm})`);
    og.addColorStop(1,`rgba(${col.r},${col.g},${col.b},0)`);
    ctx.fillStyle=og;ctx.beginPath();ctx.arc(x,y,glowR,0,Math.PI*2);ctx.fill();
    const bg=ctx.createRadialGradient(x-r*0.12,y-r*0.12,0,x,y,r);
    bg.addColorStop(0,`rgba(${Math.min(255,col.r+25)},${Math.min(255,col.g+25)},${Math.min(255,col.b+25)},${opacity*0.6})`);
    bg.addColorStop(0.45,`rgba(${col.r},${col.g},${col.b},${opacity*0.35})`);
    bg.addColorStop(0.8,`rgba(${col.r},${col.g},${col.b},${opacity*0.45})`);
    bg.addColorStop(1,`rgba(${Math.max(0,col.r-25)},${Math.max(0,col.g-25)},${Math.max(0,col.b-25)},${opacity*0.12})`);
    ctx.fillStyle=bg;ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fill();
    if(bm<1.5){ctx.strokeStyle=`rgba(${Math.min(255,col.r+40)},${Math.min(255,col.g+40)},${Math.min(255,col.b+40)},${opacity*0.18/bm})`;ctx.lineWidth=r>30?1.2:0.7;ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.stroke();}
    const nr=r*(bm>1.3?0.18:0.22);const ng=ctx.createRadialGradient(x,y,0,x,y,nr);
    ng.addColorStop(0,`rgba(255,255,255,${opacity*(bm>1.3?0.2:0.45)})`);ng.addColorStop(0.5,`rgba(${Math.min(255,col.r+50)},${Math.min(255,col.g+50)},${Math.min(255,col.b+50)},${opacity*0.2})`);ng.addColorStop(1,`rgba(${col.r},${col.g},${col.b},0)`);
    ctx.fillStyle=ng;ctx.beginPath();ctx.arc(x,y,nr,0,Math.PI*2);ctx.fill();
    if(r>18&&bm<1.3){const hg=ctx.createRadialGradient(x-r*0.26,y-r*0.26,0,x-r*0.26,y-r*0.26,r*0.16);hg.addColorStop(0,`rgba(255,255,255,${opacity*0.22})`);hg.addColorStop(1,'rgba(255,255,255,0)');ctx.fillStyle=hg;ctx.beginPath();ctx.arc(x-r*0.26,y-r*0.26,r*0.16,0,Math.PI*2);ctx.fill();}
  }

  function collideLayer(cells){for(let i=0;i<cells.length;i++){for(let j=i+1;j<cells.length;j++){const a=cells[i],b=cells[j];const dx=b.x-a.x,dy=b.y-a.y,dist=Math.sqrt(dx*dx+dy*dy),minD=a.r+b.r;
    if(dist<minD&&dist>0.1){const nx=dx/dist,ny=dy/dist,overlap=minD-dist,total=a.mass+b.mass;a.vx-=nx*overlap*(b.mass/total)*0.01;a.vy-=ny*overlap*(b.mass/total)*0.01;b.vx+=nx*overlap*(a.mass/total)*0.01;b.vy+=ny*overlap*(a.mass/total)*0.01;}}}}

  const{ctx,gW,gH,gM}=heroSetup();let time=0;
  const W0=gW(),H0=gH();
  const layers=[[],[],[]];
  // Back
  [{count:5,rMin:70,rMax:130,speed:0.03,opBase:0.035,opScale:1500,parallax:0.15,blur:2},
   {count:15,rMin:15,rMax:45,speed:0.15,opBase:0.1,opScale:250,parallax:0.45,blur:1},
   {count:8,rMin:3,rMax:6,speed:0.3,opBase:0.25,opScale:40,parallax:0.8,blur:0.7}].forEach((conf,li)=>{
    for(let i=0;i<conf.count;i++){const r=conf.rMin+Math.random()*(conf.rMax-conf.rMin);
      layers[li].push({x:Math.random()*W0,y:Math.random()*H0,vx:(Math.random()-0.5)*conf.speed,vy:(Math.random()-0.5)*conf.speed,
        r,mass:r*r,color:palWarm[Math.floor(Math.random()*palWarm.length)],opacity:conf.opBase+r/conf.opScale,
        ph:Math.random()*Math.PI*2,ps:0.005+li*0.004+Math.random()*0.005,pa:2-li*0.6+Math.random()*(2-li),
        parallax:conf.parallax,blur:conf.blur});}});

  function draw(){
    time++;const W=gW(),H=gH(),m=gM();ctx.clearRect(0,0,W,H);
    const ag=ctx.createRadialGradient(W*0.4,H*0.35,0,W*0.4,H*0.35,W*0.45);
    ag.addColorStop(0,'rgba(108,26,85,0.05)');ag.addColorStop(1,'transparent');ctx.fillStyle=ag;ctx.fillRect(0,0,W,H);
    layers.forEach((layer,li)=>{
      layer.forEach(c=>{c.vx+=Math.sin(time*0.002+c.ph)*0.0006;c.vy+=Math.cos(time*0.0015+c.ph)*0.0006;c.vx*=0.997;c.vy*=0.997;
        const spd=Math.sqrt(c.vx*c.vx+c.vy*c.vy),mx2=0.5/(c.r/25);if(spd>mx2){c.vx=(c.vx/spd)*mx2;c.vy=(c.vy/spd)*mx2;}
        c.x+=c.vx;c.y+=c.vy;const mg=c.r+30;if(c.x<-mg)c.x=W+mg;if(c.x>W+mg)c.x=-mg;if(c.y<-mg)c.y=H+mg;if(c.y>H+mg)c.y=-mg;});
      collideLayer(layer);
      let offX=0,offY=0;
      layer.forEach(c=>{const p=Math.sin(time*c.ps+c.ph)*c.pa;drawCell(ctx,c.x+offX,c.y+offY,c.r+p,c.color,c.opacity,c.blur);});
    });
  }
  return draw;
});

// ═══ CORD BLOOD SCROLLYTELLING — Cell visualization ═══
animateWhenVisible('cellCanvas', () => {
  const canvas=document.getElementById('cellCanvas');const ctx=canvas.getContext('2d');let W,H,time=0;
  const stepColors=[{main:'#3B6DC4',glow:'rgba(59,109,196,0.08)',ring:'rgba(59,109,196,0.2)'},
    {main:'#6C1A55',glow:'rgba(108,26,85,0.08)',ring:'rgba(108,26,85,0.2)'},
    {main:'#3D8B6A',glow:'rgba(61,139,106,0.08)',ring:'rgba(61,139,106,0.2)'},
    {main:'#C4943E',glow:'rgba(196,148,62,0.08)',ring:'rgba(196,148,62,0.2)'}];
  let targetStep=0,cells=[];
  // Per-cell smooth transition weights
  let cellWeights=[];
  function resize(){const p=canvas.parentElement;W=p.offsetWidth;H=p.offsetHeight;const s=safeDPR;canvas.width=W*s;canvas.height=H*s;ctx.setTransform(s,0,0,s,0,0);if(!cells.length)initCells();}
  function initCells(){cells=[];cellWeights=[];for(let i=0;i<60;i++){cells.push({x:W/2+(Math.random()-0.5)*300,y:H/2+(Math.random()-0.5)*300,r:Math.random()*4+2,vx:(Math.random()-0.5)*0.2,vy:(Math.random()-0.5)*0.2,phase:Math.random()*Math.PI*2,cat:Math.floor(Math.random()*4)});cellWeights.push(0);}}
  resize();window.addEventListener('resize',resize);
  // Smooth color interpolation
  let dispStep=0; // 0-3 float for smooth color transition
  function lerpColor(a,b,t){return{main:a.main,glow:a.glow,ring:a.ring};}
  function draw(){
    time+=0.008;ctx.clearRect(0,0,W,H);
    // Smooth step transition
    dispStep+=(targetStep-dispStep)*0.04;
    const si=Math.floor(dispStep),sn=Math.min(3,si+1);
    const frac=dispStep-si;
    const scA=stepColors[si],scB=stepColors[sn];
    // Interpolate glow/ring colors
    function parseRGBA(s){const m=s.match(/[\d.]+/g);return m?m.map(Number):[0,0,0,0];}
    const glowA=parseRGBA(scA.glow),glowB=parseRGBA(scB.glow);
    const ringA=parseRGBA(scA.ring),ringB=parseRGBA(scB.ring);
    const glowI=`rgba(${glowA[0]+(glowB[0]-glowA[0])*frac|0},${glowA[1]+(glowB[1]-glowA[1])*frac|0},${glowA[2]+(glowB[2]-glowA[2])*frac|0},${(glowA[3]+(glowB[3]-glowA[3])*frac).toFixed(3)})`;
    const ringI=`rgba(${ringA[0]+(ringB[0]-ringA[0])*frac|0},${ringA[1]+(ringB[1]-ringA[1])*frac|0},${ringA[2]+(ringB[2]-ringA[2])*frac|0},${(ringA[3]+(ringB[3]-ringA[3])*frac).toFixed(3)})`;
    // Central glow
    const grad=ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,200);grad.addColorStop(0,glowI);grad.addColorStop(1,'transparent');ctx.fillStyle=grad;ctx.fillRect(0,0,W,H);
    // Pulsing rings
    for(let r=0;r<3;r++){const radius=80+r*50+Math.sin(time+r)*8;ctx.strokeStyle=ringI;ctx.lineWidth=1;ctx.globalAlpha=0.3-r*0.08;ctx.beginPath();ctx.arc(W/2,H/2,radius,0,Math.PI*2);ctx.stroke();}
    ctx.globalAlpha=1;
    // Cells with smooth per-cell weight
    cells.forEach((c,ci)=>{
      c.x+=c.vx+Math.sin(time+c.phase)*0.3;c.y+=c.vy+Math.cos(time*0.8+c.phase)*0.3;
      const dx=W/2-c.x,dy=H/2-c.y,dist=Math.sqrt(dx*dx+dy*dy);if(dist>180){c.vx+=dx*0.0005;c.vy+=dy*0.0005;}c.vx*=0.99;c.vy*=0.99;
      // Smooth weight: 1 when active, 0 when not
      const tgt=c.cat===targetStep?1:0;
      cellWeights[ci]+=(tgt-cellWeights[ci])*0.03;
      const w=cellWeights[ci];
      const alpha=0.08+w*0.62;
      const size=c.r*(1+w*0.3);
      ctx.globalAlpha=alpha;ctx.fillStyle=stepColors[c.cat].main;
      ctx.beginPath();ctx.arc(c.x,c.y,size,0,Math.PI*2);ctx.fill();});
    // Center label — smooth
    ctx.globalAlpha=1;
    const labels=['01','02','03','04'];
    // Outgoing label fades out, incoming fades in
    if(Math.abs(dispStep-targetStep)>0.01){
      ctx.font='600 48px "Source Serif 4",serif';ctx.textAlign='center';
      ctx.globalAlpha=0.15*(1-frac);ctx.fillStyle=scA.main;ctx.fillText(labels[si],W/2,H/2+16);
      ctx.globalAlpha=0.15*frac;ctx.fillStyle=scB.main;ctx.fillText(labels[sn],W/2,H/2+16);
    }else{
      ctx.font='600 48px "Source Serif 4",serif';ctx.fillStyle=stepColors[targetStep].main;ctx.textAlign='center';ctx.globalAlpha=0.15;
      ctx.fillText(labels[targetStep],W/2,H/2+16);
    }
    ctx.globalAlpha=1;
  }
  const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){targetStep=parseInt(e.target.dataset.step);
    document.querySelectorAll('#scrollyCB .scrolly-step-inner').forEach(el=>el.classList.remove('active'));
    e.target.querySelector('.scrolly-step-inner').classList.add('active');
    if(reduceMotion){dispStep=targetStep;const c=document.getElementById('cellCanvas');if(c&&c._drawFn)c._drawFn();}
    }});},{threshold:0.25,rootMargin:'-35% 0px -10% 0px'});
  document.querySelectorAll('[data-step]').forEach(el=>obs.observe(el));
  return draw;
});

