          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">CML</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">JMML</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">CLL</span>
