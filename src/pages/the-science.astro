          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">DLBCL</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">Follicular</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">Burkitt</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">Mantle cell</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">Myeloma</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.7);border-color:rgba(232,160,208,0.12);">MDS</span>
          <span class="dlm-tag" style="color:rgba(232,160,208,0.5);border-color:rgba(232,160,208,0.08);">+8 more</span>
        </div>
      </div>
      <div class="dlm-category">
        <div class="dlm-cat-header"><div class="dlm-cat-dot" style="background:#6B9BED;"></div><div class="dlm-cat-title" style="color:#6B9BED;">Blood Disorders</div></div>
