.hero-lbl{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--pink);margin-bottom:14px;
  opacity:0;transform:translateY(20px);animation:fu 0.8s 0.3s forwards;}
.hero h1{font-family:'Playfair Display',serif;font-size:52px;font-weight:400;line-height:1.08;letter-spacing:-1.5px;
  max-width:700px;margin-bottom:16px;color:#fff;opacity:0;transform:translateY(30px);animation:fu 0.8s 0.5s forwards;}
.hero .sub{font-size:17px;color:rgba(255,255,255,0.45);max-width:500px;line-height:1.7;
  opacity:0;transform:translateY(20px);animation:fu 0.8s 0.7s forwards;}
@keyframes fu{to{opacity:1;transform:translateY(0);}}

/* SECTION TITLES (Style A) */
