          <span class="dlm-tag" style="color:rgba(107,155,237,0.7);border-color:rgba(107,155,237,0.12);">PNH</span>
          <span class="dlm-tag" style="color:rgba(107,155,237,0.7);border-color:rgba(107,155,237,0.12);">Myelofibrosis</span>
          <span class="dlm-tag" style="color:rgba(107,155,237,0.5);border-color:rgba(107,155,237,0.08);">+10 more</span>
        </div>
      </div>
      <div class="dlm-category">
        <div class="dlm-cat-header"><div class="dlm-cat-dot" style="background:#5DB890;"></div><div class="dlm-cat-title" style="color:#5DB890;">Immune Deficiencies</div></div>
