          <span style="color:#E8A0D0;">Cord Blood Treatments</span>
        </div>
      </div>
      <div class="sr" data-d="150">
        <div style="font-family:'Playfair Display',serif;font-size:38px;font-weight:400;color:#fff;padding-bottom:20px;">80+ diseases treated with cord blood</div>
      </div>
    </div>
    <div class="starburst-wrap" id="starburstWrap"><canvas id="starburstCanvas"></canvas></div>
    <div class="cat-cards">
      <div class="cat-card" data-cat="0"><div class="cat-card-count" style="color:#E8A0D0;">22+</div><div class="cat-card-name" style="color:#E8A0D0;">Cancers</div></div>
      <div class="cat-card" data-cat="1"><div class="cat-card-count" style="color:#6B9BED;">17+</div><div class="cat-card-name" style="color:#6B9BED;">Blood disorders</div></div>
      <div class="cat-card" data-cat="2"><div class="cat-card-count" style="color:#5DB890;">30+</div><div class="cat-card-name" style="color:#5DB890;">Immune deficiencies</div></div>
      <div class="cat-card" data-cat="3"><div class="cat-card-count" style="color:#E8C06E;">16+</div><div class="cat-card-name" style="color:#E8C06E;">Metabolic disorders</div></div>
    </div>
    <div class="disease-list-mobile">
      <div class="dlm-category">
        <div class="dlm-cat-header"><div class="dlm-cat-dot" style="background:#E8A0D0;"></div><div class="dlm-cat-title" style="color:#E8A0D0;">Cancers</div></div>
        <div class="dlm-diseases">
