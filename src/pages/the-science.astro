---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroOsmos from '../components/islands/HeroOsmos.jsx';
import CellScrolly from '../components/islands/CellScrolly.jsx';
import Starburst from '../components/islands/Starburst.jsx';
import ArcScrolly from '../components/islands/ArcScrolly.jsx';
import ManifestoParticles from '../components/islands/ManifestoParticles.jsx';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "The Science of Cord Blood Stem Cells",
  "description": "Learn how cord blood stem cells treat 80+ diseases today and are being researched for hundreds more.",
  "url": "https://stemcyte.com/the-science",
  "specialty": "Hematology"
};
---
<BaseLayout title="The Science" schema={schema}>

<div class="scroll-progress" id="scrollProgress"></div>

<!-- ═══ HERO ═══ -->
<section class="hero" id="hero">
  <HeroOsmos client:load />
  <div class="hero-vig"></div>
  <div class="hero-ct">
    <div class="hero-lbl">The Science</div>
    <h1>Your baby is born with the power to save a life — including their own</h1>
    <p class="sub">Your newborn's umbilical cord contains stem cells that treat over 80 diseases today and are being researched for hundreds more.</p>
  </div>
  <div class="scroll-hint"><div class="scroll-mouse"></div><span>Scroll</span></div>
</section>

<!-- ═══ SECTION TITLE: Cord Blood ═══ -->
<div class="stitle">
  <div class="sr" data-d="0">
    <div class="stitle-pill" style="border-color:rgba(59,109,196,0.15);">
      <span style="color:#6B9BED;">Cord Blood</span>
    </div>
  </div>
  <div class="sr" data-d="150">
    <h2>What are cord blood stem cells?</h2>
  </div>
  <div class="sr" data-d="400">
    <p class="stitle-sub">Think of stem cells as your body's starter kit. They're the original cells that every other cell in your body comes from.</p>
  </div>
</div>

<!-- ═══ CORD BLOOD SCROLLYTELLING ═══ -->
<section class="scrolly" id="scrollyCB">
  <div class="scrolly-inner">
    <div class="scrolly-text">
      <div class="scrolly-step" data-step="0"><div class="scrolly-step-inner active">
        <div class="step-num" style="color:rgba(59,109,196,0.15)">01</div>
        <h2 style="color:var(--blue)">Your baby is born with them</h2>
        <p>The blood left in your baby's umbilical cord after birth is rich with <strong>stem cells</strong> — the same type used in bone marrow transplants for decades. They build your baby's entire blood and immune system.</p>
      </div></div>
      <div class="scrolly-step" data-step="1"><div class="scrolly-step-inner">
        <div class="step-num" style="color:rgba(108,26,85,0.1)">02</div>
        <h2 style="color:var(--plum)">They can rebuild what's broken</h2>
        <p>Every red blood cell, white blood cell, and platelet traces back to these stem cells. When someone fights leukemia, sickle cell disease, or an immune deficiency, <strong>a transplant can regenerate their entire blood and immune system</strong>.</p>
      </div></div>
      <div class="scrolly-step" data-step="2"><div class="scrolly-step-inner">
        <div class="step-num" style="color:rgba(61,139,106,0.1)">03</div>
        <h2 style="color:var(--sage)">Younger, stronger, unexposed</h2>
        <p>Collected at the moment of birth, cord blood stem cells have had <strong>zero exposure to environmental toxins, illness, or aging</strong>. They're a biological snapshot of your child's health at its purest.</p>
      </div></div>
      <div class="scrolly-step" data-step="3"><div class="scrolly-step-inner">
        <div class="step-num" style="color:rgba(196,148,62,0.1)">04</div>
        <h2 style="color:var(--amber)">Protection for the whole family</h2>
        <p>A guaranteed <strong>perfect match for your baby</strong>, 75% chance for siblings, and because cord blood requires less strict HLA matching than bone marrow — parents and extended family too.</p>
      </div></div>
    </div>
    <div class="scrolly-visual">
      <CellScrolly client:visible sectionId="scrollyCB" />
    </div>
  </div>
</section>

<!-- ═══ SECTION TITLE: Disease Starburst ═══ -->
<div class="stitle" style="background:var(--plum-deep);padding-bottom:0;">
  <div class="sr" data-d="0">
    <div class="stitle-pill" style="border-color:rgba(232,160,208,0.2);">
      <span style="color:#E8A0D0;">Established Treatments</span>
    </div>
  </div>
  <div class="sr" data-d="150">
    <h2 style="color:#fff;">85+ diseases treated with cord blood</h2>
  </div>
</div>

<!-- ═══ DISEASE STARBURST ═══ -->
<section class="disease-section" id="diseases">
  <div class="disease-inner">
    <Starburst client:visible />
    <div class="cat-cards">
      <div class="cat-card" data-cat="0"><div class="cat-card-count" style="color:#E8A0D0;">22+</div><div class="cat-card-name" style="color:#E8A0D0;">Cancers</div></div>
      <div class="cat-card" data-cat="1"><div class="cat-card-count" style="color:#6B9BED;">17+</div><div class="cat-card-name" style="color:#6B9BED;">Blood disorders</div></div>
      <div class="cat-card" data-cat="2"><div class="cat-card-count" style="color:#5DB890;">30+</div><div class="cat-card-name" style="color:#5DB890;">Immune deficiencies</div></div>
      <div class="cat-card" data-cat="3"><div class="cat-card-count" style="color:#E8C06E;">16+</div><div class="cat-card-name" style="color:#E8C06E;">Metabolic disorders</div></div>
    </div>
  </div>
</section>

<!-- ═══ SECTION TITLE: Cord Tissue ═══ -->
<div class="stitle">
  <div class="sr" data-d="0">
    <div class="stitle-pill" style="border-color:rgba(42,107,79,0.2);">
      <span style="color:#5DB890;">Cord Tissue</span>
    </div>
  </div>
  <div class="sr" data-d="150">
    <h2>What are cord tissue stem cells?</h2>
  </div>
  <div class="sr" data-d="400">
    <p class="stitle-sub">Your umbilical cord contains a second type of stem cell — one that doesn't build blood, but repairs and rebuilds the body itself.</p>
  </div>
</div>

<!-- ═══ CORD TISSUE SCROLLYTELLING ═══ -->
<section class="scrolly scrolly-tissue" id="scrollyCT">
  <div class="scrolly-inner">
    <div class="scrolly-text">
      <div class="scrolly-step" data-tstep="0"><div class="scrolly-step-inner">
        <div class="step-num" style="color:rgba(42,107,79,0.08)">05</div>
        <h2 style="color:var(--sage)">There's more than blood in the cord</h2>
        <p>The umbilical cord itself — the tissue — contains a different type of stem cell called <strong>mesenchymal stem cells (MSCs)</strong>. They live inside a jelly-like substance called Wharton's jelly.</p>
      </div></div>
      <div class="scrolly-step" data-tstep="1"><div class="scrolly-step-inner">
        <div class="step-num" style="color:rgba(42,107,79,0.08)">06</div>
        <h2 style="color:var(--sage)">They repair, not replace</h2>
        <p>Where cord blood rebuilds your blood and immune system, cord tissue MSCs repair <strong>structural tissue — muscle, bone, cartilage, skin, and organs</strong>. They're the body's construction crew.</p>
      </div></div>
      <div class="scrolly-step" data-tstep="2"><div class="scrolly-step-inner">
        <div class="step-num" style="color:rgba(42,107,79,0.08)">07</div>
        <h2 style="color:var(--sage)">No matching required</h2>
        <p>Unlike cord blood, MSCs <strong>don't require HLA matching</strong>. That means they could potentially be used by any family member — parents, siblings, even grandparents — without the compatibility barrier.</p>
      </div></div>
      <div class="scrolly-step" data-tstep="3"><div class="scrolly-step-inner">
        <div class="step-num" style="color:rgba(42,107,79,0.08)">08</div>
        <h2 style="color:var(--sage)">Collected once, from the same cord</h2>
        <p>Cord tissue is collected at the same time as cord blood — <strong>same birth, same moment, no extra procedure</strong>. One collection gives your family two different types of stem cells with two different futures.</p>
      </div></div>
    </div>
    <div class="scrolly-visual">
      <ArcScrolly client:visible sectionId="scrollyCT" />
    </div>
  </div>
</section>

<!-- ═══ MANIFESTO: Cord Tissue Future ═══ -->
<section class="manifesto-section" id="manifesto">
  <ManifestoParticles client:visible sectionId="manifesto" />
  <div class="manifesto-content">
    <div style="text-align:center;margin-bottom:72px;">
      <div class="sr" data-d="0" style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#5DB890;margin-bottom:12px;">Beyond cord blood</div>
      <div class="sr" data-d="150" style="font-family:'Playfair Display',serif;font-size:44px;font-weight:400;line-height:1.2;color:#fff;">Ten reasons cord tissue<br>is the future of medicine.</div>
      <div class="sr" data-d="300" style="font-size:15px;color:rgba(255,255,255,0.3);max-width:440px;margin:12px auto 0;">One collection. One moment. A lifetime of possibilities that science is just beginning to unlock.</div>
    </div>
    <div class="manifesto-list" id="manifestoList">
      <div class="manifesto-line"></div>
    </div>
    <div style="text-align:center;margin-top:56px;">
      <div class="stat-500" style="font-family:'Source Serif 4',serif;font-size:56px;color:rgba(93,184,144,0.12);">500+</div>
      <div style="font-size:12px;color:rgba(255,255,255,0.2);margin-top:-6px;">active MSC clinical trials worldwide</div>
      <div style="margin-top:20px;">
        <a href="/clinical-trials" class="btn-ghost-sage">View StemCyte clinical trials &rarr;</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style is:global>
  :root {
    --plum: #6C1A55;
    --plum-deep: #3D0F31;
    --pink: #E8A0D0;
    --cream: #FAF7F2;
    --lav: #F3F0F8;
    --lav-deep: #EDE8F5;
    --blue: #3B6DC4;
    --sage: #3D8B6A;
    --sage-deep: #0F2E22;
    --sage-light: #5DB890;
    --amber: #C4943E;
    --text: #2C2A26;
    --muted: #6B665D;
    --light: #8A857A;
  }

  /* SCROLL PROGRESS */
  .scroll-progress {
    position: fixed; top: 0; left: 0; height: 3px; z-index: 9999;
    background: linear-gradient(90deg, var(--plum), var(--pink), var(--blue), var(--sage));
    width: 0; transition: width 0.05s linear;
  }

  /* SCROLL REVEAL */
  .sr { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .sr.vis { opacity: 1; transform: translateY(0); }

  /* HERO */
  .hero {
    position: relative; min-height: 100vh; display: flex; align-items: flex-end;
    overflow: hidden; background: #1a0a14;
  }
  .hero-vig {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(to top, rgba(26,10,20,0.9) 0%, rgba(26,10,20,0.3) 40%, transparent 100%);
  }
  .hero-ct {
    position: relative; z-index: 3; max-width: 1100px;
    margin: 0 auto; padding: 0 48px 80px; width: 100%;
  }
  .hero-lbl {
    font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: var(--pink); margin-bottom: 14px;
    opacity: 0; transform: translateY(20px); animation: fu 0.8s 0.3s forwards;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif; font-size: 52px; font-weight: 400;
    line-height: 1.08; letter-spacing: -1.5px; max-width: 700px; margin-bottom: 16px;
    color: #fff; opacity: 0; transform: translateY(30px); animation: fu 0.8s 0.5s forwards;
  }
  .hero .sub {
    font-size: 17px; color: rgba(255,255,255,0.45); max-width: 500px; line-height: 1.7;
    opacity: 0; transform: translateY(20px); animation: fu 0.8s 0.7s forwards;
  }
  @keyframes fu { to { opacity: 1; transform: translateY(0); } }

  .scroll-hint {
    position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 4;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0; animation: fu 0.8s 1.2s forwards;
  }
  .scroll-hint span {
    font-size: 10px; color: rgba(255,255,255,0.3); letter-spacing: 2px;
    text-transform: uppercase; font-weight: 700;
  }
  .scroll-mouse {
    width: 20px; height: 32px; border: 2px solid rgba(255,255,255,0.2);
    border-radius: 10px; position: relative;
  }
  .scroll-mouse::after {
    content: ''; width: 3px; height: 6px; border-radius: 2px;
    background: rgba(255,255,255,0.4); position: absolute; top: 6px;
    left: 50%; transform: translateX(-50%); animation: sb 1.5s ease-in-out infinite;
  }
  @keyframes sb {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50% { transform: translateX(-50%) translateY(8px); opacity: 0.3; }
  }

  /* SECTION TITLES (Style A) */
  .stitle { text-align: center; padding: 80px 48px 48px; }
  .stitle-pill {
    display: inline-block; padding: 4px 14px; border-radius: 100px;
    border: 1px solid; margin-bottom: 12px;
  }
  .stitle-pill span {
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
  }
  .stitle h2 {
    font-family: 'Playfair Display', serif; font-size: 38px; font-weight: 400;
    color: var(--text);
  }
  .stitle-sub {
    font-size: 16px; color: var(--muted); max-width: 520px; margin: 10px auto 0;
    line-height: 1.7;
  }

  /* SCROLLYTELLING (shared) */
  .scrolly { position: relative; background: var(--cream); }
  .scrolly-inner {
    display: grid; grid-template-columns: 1fr 1fr; max-width: 1100px;
    margin: 0 auto; min-height: 400vh;
  }
  .scrolly-text { position: relative; z-index: 2; padding: 0 48px; }
  .scrolly-step { min-height: 100vh; display: flex; align-items: center; padding: 40px 0; }
  .scrolly-step-inner {
    max-width: 420px; opacity: 0.15; transform: translateY(20px);
    transition: all 0.6s ease;
  }
  .scrolly-step-inner.active { opacity: 1; transform: translateY(0); }
  .step-num {
    font-family: 'Source Serif 4', serif; font-size: 72px; font-weight: 400;
    line-height: 1; margin-bottom: 8px; opacity: 0.1;
  }
  .scrolly-step-inner h2 {
    font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 400;
    line-height: 1.2; margin-bottom: 14px;
  }
  .scrolly-step-inner p { font-size: 15px; color: var(--muted); line-height: 1.8; }
  .scrolly-step-inner p strong { color: var(--text); }
  .scrolly-visual {
    position: sticky; top: 0; height: 100vh;
    display: flex; align-items: center; justify-content: center;
  }
  .scrolly-visual canvas { width: 100%; height: 100%; display: block; }
  .scrolly-visual astro-island { display: block; width: 100%; height: 100%; }

  /* Cord tissue scrolly — flipped */
  .scrolly-tissue .scrolly-visual { order: -1; }

  /* DISEASE STARBURST */
  .disease-section {
    background: radial-gradient(ellipse 70% 60% at 50% 45%, #4A1840 0%, #2A0E22 40%, #150818 100%);
    padding: 120px 48px; position: relative; overflow: hidden;
  }
  .disease-inner { max-width: 1100px; margin: 0 auto; position: relative; z-index: 2; }
  .cat-cards { display: flex; gap: 10px; justify-content: center; margin-top: 16px; }
  .cat-card {
    background: rgba(255,255,255,0.04); backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.06); border-radius: 12px;
    padding: 18px 20px; text-align: center; width: 170px; cursor: default;
    transition: all 0.25s;
  }
  .cat-card:hover {
    border-color: rgba(255,255,255,0.12); background: rgba(255,255,255,0.06);
  }
  .cat-card-count { font-family: 'Source Serif 4', serif; font-size: 24px; line-height: 1; }
  .cat-card-name { font-size: 11px; font-weight: 700; margin-top: 6px; }

  /* MANIFESTO */
  .manifesto-section {
    background: var(--sage-deep); padding: 100px 48px 80px;
    position: relative; overflow: hidden; color: #fff;
  }
  .manifesto-content { position: relative; z-index: 2; }
  .manifesto-list { max-width: 640px; margin: 0 auto; position: relative; }
  .manifesto-line {
    position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(93,184,144,0.08) 5%, rgba(93,184,144,0.08) 95%, transparent);
  }
  .m-block {
    display: flex; align-items: flex-start; gap: 20px; padding: 28px 0;
    position: relative; cursor: default; transition: all 0.3s;
  }
  .m-block.left { flex-direction: row; text-align: left; padding-right: 52%; }
  .m-block.right { flex-direction: row-reverse; text-align: right; padding-left: 52%; }
  .m-dot {
    position: absolute; left: 50%; top: 36px; width: 8px; height: 8px;
    border-radius: 50%; background: rgba(93,184,144,0.15);
    transform: translateX(-50%); transition: all 0.4s; z-index: 2;
  }
  .m-num {
    font-family: 'Source Serif 4', serif; font-size: 36px;
    color: rgba(93,184,144,0.15); line-height: 1; margin-bottom: 6px;
    transition: color 0.3s;
  }
  .m-title {
    font-size: 18px; font-weight: 700; color: rgba(255,255,255,0.6);
    margin-bottom: 6px; transition: color 0.3s;
  }
  .m-desc {
    font-size: 13px; color: rgba(255,255,255,0.2); line-height: 1.55;
    transition: color 0.3s;
  }
  .m-block:hover .m-dot {
    background: #5DB890; transform: translateX(-50%) scale(1.8);
    box-shadow: 0 0 16px rgba(93,184,144,0.4);
  }
  .m-block:hover .m-num { color: rgba(93,184,144,0.4); }
  .m-block:hover .m-title { color: #fff; }
  .m-block:hover .m-desc { color: rgba(255,255,255,0.45); }

  /* Ghost button sage */
  .btn-ghost-sage {
    display: inline-block; color: #5DB890; padding: 12px 28px;
    border-radius: 100px; font-size: 14px; font-weight: 700;
    text-decoration: none; border: 1px solid rgba(93,184,144,0.2);
    transition: all 0.25s;
  }
  .btn-ghost-sage:hover {
    background: rgba(93,184,144,0.08); border-color: rgba(93,184,144,0.35);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-ct { padding: 0 24px 60px; }
    .hero h1 { font-size: 34px; }
    .scrolly-inner { grid-template-columns: 1fr; }
    .scrolly-visual { display: none; }
    .scrolly-text { padding: 0 24px; }
    .scrolly-tissue .scrolly-visual { display: none; }
    .disease-section, .manifesto-section { padding: 80px 24px; }
    .starburst-wrap { height: 350px; }
    .cat-cards { flex-wrap: wrap; justify-content: center; }
    .stitle { padding: 60px 24px 32px; }
    .stitle h2 { font-size: 28px; }
    .m-block.left, .m-block.right {
      padding-right: 0; padding-left: 0;
      flex-direction: column; text-align: left; padding-left: 52%;
    }
  }
</style>

<script>
  // Scroll progress bar
  window.addEventListener('scroll', () => {
    const h = document.documentElement.scrollHeight - window.innerHeight;
    const bar = document.getElementById('scrollProgress');
    if (bar) bar.style.width = (window.scrollY / h) * 100 + '%';
  });

  // Scroll reveal for .sr elements
  const srObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const d = parseInt(e.target.dataset.d || 0);
        setTimeout(() => e.target.classList.add('vis'), d);
        srObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.sr').forEach(el => srObs.observe(el));
</script>
