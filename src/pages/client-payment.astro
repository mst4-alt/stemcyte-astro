---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaymentForm from '../components/islands/PaymentForm.jsx';
---
<BaseLayout title="Client Payment">

<div id="hero" class="hero">
  <div class="hero-deco"></div>
  <div class="ct">
    <div class="lbl">Account</div>
    <h1>Client Payment</h1>
    <p class="sub">Make a payment toward your StemCyte account.</p>
  </div>
</div>

<div class="section">
  <PaymentForm client:load />
</div>

</BaseLayout>

<style is:global>
.hero {
  position:relative; min-height:320px; display:flex; align-items:flex-end; overflow:hidden;
  background:linear-gradient(160deg,#6C1A55,#3D0F31);
}
.hero-deco {
  position:absolute; width:500px; height:500px; border-radius:50%;
  background:rgba(192,106,165,0.08); top:-200px; right:-100px; pointer-events:none;
}
.ct { position:relative; z-index:2; max-width:1100px; margin:0 auto; padding:140px 48px 52px; width:100%; }
.lbl { font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#E8A0D0; margin-bottom:10px; }
.hero h1 { font-family:'Playfair Display',serif; font-size:42px; font-weight:400; line-height:1.1; letter-spacing:-1.5px; max-width:680px; margin-bottom:10px; color:#fff; }
.sub { font-size:16px; color:rgba(255,255,255,0.6); max-width:440px; line-height:1.7; }
.section { padding:80px 48px; max-width:900px; margin:0 auto; }
@media (max-width:900px) {
  .ct { padding:120px 24px 40px; }
  .hero h1 { font-size:32px; }
  .section { padding:64px 24px; }
}
</style>
