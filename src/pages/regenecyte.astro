            <div class="vbar-group">
              <div class="vbar-pair">
                <div class="vbar neutral" style="height:167px;"><div class="vbar-val">76%</div></div>
                <div class="vbar accent" style="height:200px;"><div class="vbar-val">91%</div></div>
              </div>
              <div class="vbar-label">Neutrophil<br>Day 42</div>
            </div>
            <div class="vbar-group">
              <div class="vbar-pair">
                <div class="vbar neutral" style="height:125px;"><div class="vbar-val">57%</div></div>
                <div class="vbar accent" style="height:158px;"><div class="vbar-val">72%</div></div>
              </div>
              <div class="vbar-label">Platelet 20K<br>Day 100</div>
            </div>
            <div class="vbar-group">
              <div class="vbar-pair">
                <div class="vbar neutral" style="height:101px;"><div class="vbar-val">46%</div></div>
                <div class="vbar accent" style="height:160px;"><div class="vbar-val">73%</div></div>
              </div>
              <div class="vbar-label">Platelet 50K<br>Day 100</div>
            </div>
          </div>
        </div>
        <div class="chart-legend">
          <span><span class="ldot" style="background:#D8D3CC;"></span> COBLT (n=324)</span>
          <span><span class="ldot" style="background:#6C1A55;"></span> REGENECYTE (n=54)</span>
        </div>
      </div>

      <!-- Recovery time chart -->
      <div class="chart-box">
        <div class="chart-title">Time to Recovery</div>
        <div class="chart-sub">Median days &mdash; shorter is better. Scale 0&ndash;120 days.</div>
        <div class="chart-legend" style="margin-bottom:20px;margin-top:0;">
          <span><span class="ldot" style="background:#D8D3CC;"></span> COBLT</span>
          <span><span class="ldot" style="background:#6C1A55;"></span> REGENECYTE</span>
        </div>
        <div class="time-chart">
          <div class="time-row">
            <div class="time-label">Neutrophil</div>
