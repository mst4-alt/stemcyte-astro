<script is:inline>
(function() {
  var canvas = document.getElementById('cellCanvas');
  var ctx = canvas.getContext('2d');
  var hero = document.getElementById('hero');
  var W, H;
  var cells = [];
  var CELL_COUNT = 40;
  var scrollVel = 0;
  var lastScroll = 0;

  var PUSH = 0.12;
  var DEPTH_MUL = 0.025;
  var SCATTER = 0.005;
  var DECAY = 0.80;
  var DRIFT = 0.015;

  function resize() {
    var rect = hero.getBoundingClientRect();
    W = canvas.width = rect.width;
    H = canvas.height = rect.height;
    for (var i = 0; i < cells.length; i++) {
      if (cells[i].x > W) cells[i].x = W - cells[i].size;
      if (cells[i].y > H) cells[i].y = H - cells[i].size;
    }
  }
  window.addEventListener('resize', resize);
  resize();

  window.addEventListener('scroll', function() {
    var cur = window.pageYOffset;
    scrollVel = cur - lastScroll;
    lastScroll = cur;
  }, { passive: true });

  function renderSprite(type, size, squeeze, blur, opacity) {
    var pad = blur * 2 + 4;
    var w = (size * 2 + pad * 2);
    var h = (size * 2 + pad * 2);
    var oc = document.createElement('canvas');
    oc.width = Math.ceil(w);
    oc.height = Math.ceil(h);
    var ox = oc.getContext('2d');
    ox.filter = 'blur(' + blur.toFixed(1) + 'px)';
    ox.globalAlpha = opacity;
    ox.translate(oc.width / 2, oc.height / 2);

    if (type === 'rbc') {
      ox.beginPath();
      ox.ellipse(0, 0, size, size * squeeze, 0, 0, Math.PI * 2);
      var g = ox.createRadialGradient(0, -size * 0.12, size * 0.1, 0, 0, size);
      g.addColorStop(0, 'rgba(175,40,55,0.65)');
      g.addColorStop(0.3, 'rgba(140,28,42,0.4)');
      g.addColorStop(0.55, 'rgba(155,35,48,0.55)');
      g.addColorStop(0.8, 'rgba(130,25,38,0.35)');
      g.addColorStop(1, 'rgba(100,18,28,0.1)');
      ox.fillStyle = g;
      ox.fill();
      ox.beginPath();
      ox.ellipse(0, 0, size * 0.35, size * squeeze * 0.35, 0, 0, Math.PI * 2);
      var g2 = ox.createRadialGradient(0, 0, 0, 0, 0, size * 0.35);
      g2.addColorStop(0, 'rgba(70,12,20,0.3)');
      g2.addColorStop(1, 'rgba(100,20,30,0.05)');
      ox.fillStyle = g2;
      ox.fill();
      ox.beginPath();
      ox.ellipse(0, 0, size * 0.95, size * squeeze * 0.95, 0, 0, Math.PI * 2);
      ox.strokeStyle = 'rgba(200,60,80,0.08)';
      ox.lineWidth = 1;
      ox.stroke();

    } else if (type === 'wbc') {
      ox.beginPath();
      ox.ellipse(0, 0, size, size * 0.88, 0, 0, Math.PI * 2);
      var g = ox.createRadialGradient(-size * 0.1, -size * 0.1, 0, 0, 0, size);
      g.addColorStop(0, 'rgba(230,195,210,0.25)');
      g.addColorStop(0.4, 'rgba(200,140,170,0.12)');
      g.addColorStop(1, 'rgba(180,100,140,0.02)');
      ox.fillStyle = g;
      ox.fill();
      ox.beginPath();
      ox.ellipse(0, 0, size, size * 0.88, 0, 0, Math.PI * 2);
      ox.strokeStyle = 'rgba(200,130,160,0.1)';
      ox.lineWidth = 1;
      ox.stroke();
      var lobes = 2 + Math.floor(size / 15);
      for (var l = 0; l < lobes; l++) {
        var la = (l / lobes) * Math.PI * 1.4 - 0.3;
        var ld = size * 0.22;
        var lr = size * 0.18;
        ox.beginPath();
        ox.ellipse(Math.cos(la) * ld, Math.sin(la) * ld, lr, lr * 0.8, la * 0.5, 0, Math.PI * 2);
        ox.fillStyle = 'rgba(120,50,80,0.15)';
        ox.fill();
      }

    } else if (type === 'plt') {
      ox.beginPath();
      ox.ellipse(0, 0, size, size * 0.7, 0, 0, Math.PI * 2);
      var g = ox.createRadialGradient(0, 0, 0, 0, 0, size);
      g.addColorStop(0, 'rgba(220,150,175,0.75)');
      g.addColorStop(0.6, 'rgba(200,120,155,0.3)');
      g.addColorStop(1, 'rgba(180,90,130,0.05)');
      ox.fillStyle = g;
      ox.fill();

    } else {
      ox.beginPath();
      ox.arc(0, 0, size, 0, Math.PI * 2);
      var g = ox.createRadialGradient(0, -size * 0.15, 0, 0, 0, size);
      g.addColorStop(0, 'rgba(235,205,155,0.45)');
      g.addColorStop(0.4, 'rgba(200,160,80,0.2)');
      g.addColorStop(1, 'rgba(180,140,60,0.03)');
      ox.fillStyle = g;
      ox.fill();
      ox.beginPath();
      ox.arc(0, 0, size, 0, Math.PI * 2);
      ox.strokeStyle = 'rgba(200,160,80,0.08)';
      ox.lineWidth = 1;
      ox.stroke();
      ox.beginPath();
      ox.arc(size * 0.05, -size * 0.05, size * 0.3, 0, Math.PI * 2);
      ox.fillStyle = 'rgba(180,140,60,0.15)';
      ox.fill();
    }

    return oc;
  }

  function makeCell() {
    var type;
    var r = Math.random();
    if (r < 0.55) type = 'rbc';
    else if (r < 0.72) type = 'wbc';
    else if (r < 0.88) type = 'plt';
    else type = 'stem';

    var depth = 0.15 + Math.random() * 0.85;
    var baseSize;
    if (type === 'rbc') baseSize = 6 + Math.random() * 35;
    else if (type === 'wbc') baseSize = 14 + Math.random() * 45;
    else if (type === 'plt') baseSize = 2 + Math.random() * 7;
    else baseSize = 6 + Math.random() * 22;

    var size = Math.max(baseSize * depth, 2);
    var blur = (1 - depth) * 20 + 4;
    var speed = 0.1 + depth * 0.35;
    var squeeze = 0.7 + Math.random() * 0.2;
    var opacity = 0.1 + depth * 0.3;

    var sprite = renderSprite(type, size, squeeze, blur, opacity);

    return {
      type: type,
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * speed,
      vy: (Math.random() - 0.5) * speed,
      size: size, depth: depth,
      rotation: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.004,
      sprite: sprite,
      hw: sprite.width / 2,
      hh: sprite.height / 2
    };
  }

  for (var i = 0; i < CELL_COUNT; i++) cells.push(makeCell());

  cells.sort(function(a, b) { return a.depth - b.depth; });

  var GRID = 100;
  function collideAll() {
    var cols = Math.ceil(W / GRID) + 1;
    var rows = Math.ceil(H / GRID) + 1;
    var grid = {};

    for (var i = 0; i < cells.length; i++) {
      var c = cells[i];
      if (c.type === 'plt') continue;
      var gx = Math.floor(c.x / GRID);
      var gy = Math.floor(c.y / GRID);
      var key = gx + ',' + gy;
      if (!grid[key]) grid[key] = [];
      grid[key].push(i);
    }

    var keys = Object.keys(grid);
    for (var k = 0; k < keys.length; k++) {
      var bucket = grid[keys[k]];
      for (var i = 0; i < bucket.length; i++) {
        for (var j = i + 1; j < bucket.length; j++) {
          collide(cells[bucket[i]], cells[bucket[j]]);
        }
      }
      var parts = keys[k].split(',');
      var gx = parseInt(parts[0]);
      var gy = parseInt(parts[1]);
      var neighbors = [(gx+1)+','+gy, gx+','+(gy+1), (gx+1)+','+(gy+1), (gx-1)+','+(gy+1)];
      for (var n = 0; n < neighbors.length; n++) {
        var nb = grid[neighbors[n]];
        if (!nb) continue;
        for (var i = 0; i < bucket.length; i++) {
          for (var j = 0; j < nb.length; j++) {
            collide(cells[bucket[i]], cells[nb[j]]);
          }
        }
      }
    }
  }

  function collide(a, b) {
    var dx = a.x - b.x;
    var dy = a.y - b.y;
    var dist = dx * dx + dy * dy;
    var minDist = a.size + b.size;
    if (dist < minDist * minDist && dist > 0.01) {
      dist = Math.sqrt(dist);
      var nx = dx / dist;
      var ny = dy / dist;
      var push = (minDist - dist) * 0.015;
      a.vx += nx * push; a.vy += ny * push;
      b.vx -= nx * push; b.vy -= ny * push;
    }
  }

  function update() {
    var sv = scrollVel * PUSH;
    scrollVel *= DECAY;
    for (var i = 0; i < cells.length; i++) {
      var c = cells[i];
      c.vy += sv * c.depth * DEPTH_MUL;
      c.vx += sv * (Math.random() - 0.5) * c.depth * SCATTER;
      c.x += c.vx;
      c.y += c.vy;
      c.rotation += c.rotSpeed;
      if (c.x - c.size < 0) { c.x = c.size; c.vx = Math.abs(c.vx) * 0.7; }
      if (c.x + c.size > W) { c.x = W - c.size; c.vx = -Math.abs(c.vx) * 0.7; }
      if (c.y - c.size < 0) { c.y = c.size; c.vy = Math.abs(c.vy) * 0.7; }
      if (c.y + c.size > H) { c.y = H - c.size; c.vy = -Math.abs(c.vy) * 0.7; }
      c.vx *= 0.995;
      c.vy *= 0.995;
      c.vx += (Math.random() - 0.5) * DRIFT;
      c.vy += (Math.random() - 0.5) * DRIFT;
    }
    collideAll();
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    for (var i = 0; i < cells.length; i++) {
      var c = cells[i];
      ctx.save();
      ctx.translate(c.x, c.y);
      ctx.rotate(c.rotation);
      ctx.drawImage(c.sprite, -c.hw, -c.hh);
      ctx.restore();
    }
  }

  function loop() { update(); draw(); requestAnimationFrame(loop); }
  loop();
})();
</script>

</BaseLayout>
