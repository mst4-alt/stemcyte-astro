---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "StemCyte Cord Blood Banking",
  "description": "Private cord blood banking with storage plans starting at $725.",
  "brand": { "@type": "Brand", "name": "StemCyte" },
  "offers": [
    { "@type": "Offer", "name": "Cord Blood Annual", "price": "925", "priceCurrency": "USD" },
    { "@type": "Offer", "name": "Cord Blood 18-Year Prepaid", "price": "3560", "priceCurrency": "USD" },
    { "@type": "Offer", "name": "Cord Blood Lifetime", "price": "5625", "priceCurrency": "USD" }
  ]
};
---
<BaseLayout title="Pricing" schema={schema}>

<!-- HERO (compact) -->
<section class="hero" id="hero">
  <img src="/images/Hero_1.jpeg" alt="Pricing" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center" />
  <div class="vig"></div>
  <div class="ct">
    <div class="lbl">Pricing</div>
    <h1>Their future, your <em>choice</em></h1>
    <p class="sub">Choose your product, plan, and protection options.</p>
  </div>
</section>

<div class="page" id="pricing-form">
  <div id="builder">
    <!-- CELLY BANNER -->
    <div class="celly-banner" id="celly-banner" onclick="startCelly()">
      <svg class="celly-banner-av" viewBox="0 0 140 150" xmlns="http://www.w3.org/2000/svg"><defs><radialGradient id="gp" cx="44%" cy="38%" r="56%"><stop offset="0%" stop-color="#FFF5FA"/><stop offset="35%" stop-color="#F6D4EC"/><stop offset="100%" stop-color="#DA90C2"/></radialGradient></defs><g><animateTransform attributeName="transform" type="translate" values="0,0;0,-8;0,0" dur="3s" repeatCount="indefinite" calcMode="spline" keySplines="0.4 0 0.6 1;0.4 0 0.6 1"/><circle cx="70" cy="78" r="44" fill="url(#gp)"/><ellipse cx="52" cy="54" rx="20" ry="14" fill="rgba(255,255,255,0.5)"/><path d="M40 36 Q70 20, 100 36 L96 44 Q70 32, 44 44Z" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><rect x="62" y="26" width="16" height="12" rx="2" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><line x1="70" y1="28" x2="70" y2="36" stroke="#E8A0D0" stroke-width="2.5"/><line x1="66" y1="32" x2="74" y2="32" stroke="#E8A0D0" stroke-width="2.5"/><ellipse cx="54" cy="72" rx="9" ry="10.5" fill="#1E1420"><animate attributeName="ry" values="10.5;10.5;1;10.5;10.5" keyTimes="0;0.42;0.47;0.52;1" dur="5s" repeatCount="indefinite"/></ellipse><ellipse cx="86" cy="72" rx="9" ry="10.5" fill="#1E1420"><animate attributeName="ry" values="10.5;10.5;1;10.5;10.5" keyTimes="0;0.42;0.47;0.52;1" dur="5s" repeatCount="indefinite"/></ellipse><circle cx="50" cy="66" r="4" fill="#fff"/><circle cx="82" cy="66" r="4" fill="#fff"/><path d="M62 90 Q70 97, 78 90" fill="none" stroke="#1E1420" stroke-width="2.5" stroke-linecap="round"/><ellipse cx="40" cy="86" rx="8" ry="5" fill="rgba(244,150,200,0.4)"/><ellipse cx="100" cy="86" rx="8" ry="5" fill="rgba(244,150,200,0.4)"/><rect x="108" y="80" width="18" height="24" rx="3" fill="#F5EDE6" stroke="#D8D0C8" stroke-width="1.5" transform="rotate(8 117 92)"/><path d="M112 78 Q118 76, 116 84" fill="none" stroke="#DA90C2" stroke-width="4" stroke-linecap="round"/></g></svg>
      <div class="celly-banner-text">
        <div class="celly-banner-title">Not sure where to start?</div>
        <div class="celly-banner-sub">Answer 4 quick questions and Celly will build a personalized plan for you.</div>
      </div>
      <div class="celly-banner-arrow">Help me choose →</div>
    </div>

    <!-- CELLY CHAT -->
    <div class="celly-chat" id="celly-chat">
      <div class="cc-row">
        <div class="cc-av" id="cc-av">
          <!-- IDLE -->
          <svg data-state="idle" viewBox="0 0 140 150" xmlns="http://www.w3.org/2000/svg"><defs><radialGradient id="gi" cx="44%" cy="38%" r="56%"><stop offset="0%" stop-color="#FFF5FA"/><stop offset="35%" stop-color="#F6D4EC"/><stop offset="100%" stop-color="#DA90C2"/></radialGradient></defs><g><animateTransform attributeName="transform" type="translate" values="0,0;0,-8;0,0" dur="3s" repeatCount="indefinite" calcMode="spline" keySplines="0.4 0 0.6 1;0.4 0 0.6 1"/><circle cx="70" cy="78" r="44" fill="url(#gi)"/><ellipse cx="52" cy="54" rx="20" ry="14" fill="rgba(255,255,255,0.5)"/><path d="M40 36 Q70 20, 100 36 L96 44 Q70 32, 44 44Z" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><rect x="62" y="26" width="16" height="12" rx="2" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><line x1="70" y1="28" x2="70" y2="36" stroke="#E8A0D0" stroke-width="2.5"/><line x1="66" y1="32" x2="74" y2="32" stroke="#E8A0D0" stroke-width="2.5"/><ellipse cx="54" cy="72" rx="9" ry="10.5" fill="#1E1420"><animate attributeName="ry" values="10.5;10.5;1;10.5;10.5" keyTimes="0;0.42;0.47;0.52;1" dur="5s" repeatCount="indefinite"/></ellipse><ellipse cx="86" cy="72" rx="9" ry="10.5" fill="#1E1420"><animate attributeName="ry" values="10.5;10.5;1;10.5;10.5" keyTimes="0;0.42;0.47;0.52;1" dur="5s" repeatCount="indefinite"/></ellipse><circle cx="50" cy="66" r="4" fill="#fff"/><circle cx="82" cy="66" r="4" fill="#fff"/><path d="M62 90 Q70 97, 78 90" fill="none" stroke="#1E1420" stroke-width="2.5" stroke-linecap="round"/><ellipse cx="40" cy="86" rx="8" ry="5" fill="rgba(244,150,200,0.4)"/><ellipse cx="100" cy="86" rx="8" ry="5" fill="rgba(244,150,200,0.4)"/><rect x="108" y="80" width="18" height="24" rx="3" fill="#F5EDE6" stroke="#D8D0C8" stroke-width="1.5" transform="rotate(8 117 92)"/><path d="M112 78 Q118 76, 116 84" fill="none" stroke="#DA90C2" stroke-width="4" stroke-linecap="round"/></g></svg>
          <!-- WRITING: concentrated eyes (looking down), clipboard wiggle, pencil sparkle -->
          <svg data-state="writing" class="off" viewBox="0 0 140 150" xmlns="http://www.w3.org/2000/svg"><defs><radialGradient id="gw" cx="44%" cy="38%" r="56%"><stop offset="0%" stop-color="#FFF5FA"/><stop offset="35%" stop-color="#F6D4EC"/><stop offset="100%" stop-color="#DA90C2"/></radialGradient></defs><circle cx="70" cy="78" r="44" fill="url(#gw)"/><ellipse cx="52" cy="54" rx="20" ry="14" fill="rgba(255,255,255,0.5)"/><path d="M40 36 Q70 20, 100 36 L96 44 Q70 32, 44 44Z" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><rect x="62" y="26" width="16" height="12" rx="2" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><line x1="70" y1="28" x2="70" y2="36" stroke="#E8A0D0" stroke-width="2.5"/><line x1="66" y1="32" x2="74" y2="32" stroke="#E8A0D0" stroke-width="2.5"/><ellipse cx="54" cy="76" rx="8" ry="7" fill="#1E1420"/><ellipse cx="86" cy="76" rx="8" ry="7" fill="#1E1420"/><circle cx="52" cy="74" r="3" fill="#fff"/><circle cx="84" cy="74" r="3" fill="#fff"/><line x1="64" y1="92" x2="76" y2="92" stroke="#1E1420" stroke-width="2.5" stroke-linecap="round"/><ellipse cx="40" cy="86" rx="8" ry="5" fill="rgba(244,150,200,0.4)"/><ellipse cx="100" cy="86" rx="8" ry="5" fill="rgba(244,150,200,0.4)"/><g><animateTransform attributeName="transform" type="rotate" values="-2 117 92;2 117 92;-2 117 92" dur="0.4s" repeatCount="indefinite"/><rect x="108" y="80" width="18" height="24" rx="3" fill="#F5EDE6" stroke="#D8D0C8" stroke-width="1.5" transform="rotate(8 117 92)"/><line x1="112" y1="88" x2="122" y2="86" stroke="#D8D0C8" stroke-width="1"/><line x1="112" y1="92" x2="120" y2="90" stroke="#D8D0C8" stroke-width="1"/></g><path d="M112 78 Q118 76, 116 84" fill="none" stroke="#DA90C2" stroke-width="4" stroke-linecap="round"/><line x1="30" y1="82" x2="24" y2="72" stroke="#D8D0C8" stroke-width="2.5" stroke-linecap="round"><animate attributeName="y2" values="72;69;72" dur="0.3s" repeatCount="indefinite"/></line><circle cx="23" cy="70" r="2.5" fill="#FFD700"><animate attributeName="cy" values="70;67;70" dur="0.3s" repeatCount="indefinite"/></circle></svg>
          <!-- CELEBRATE: happy squint eyes, open mouth, bounce + hearts -->
          <svg data-state="happy" class="off" viewBox="0 0 140 150" xmlns="http://www.w3.org/2000/svg"><defs><radialGradient id="gh" cx="44%" cy="38%" r="56%"><stop offset="0%" stop-color="#FFF5FA"/><stop offset="35%" stop-color="#F6D4EC"/><stop offset="100%" stop-color="#DA90C2"/></radialGradient></defs><g><animateTransform attributeName="transform" type="translate" values="0,0;0,-7;0,0;0,-5;0,0;0,-2;0,0" dur="1.2s" fill="freeze"/><circle cx="70" cy="78" r="44" fill="url(#gh)"/><ellipse cx="52" cy="54" rx="20" ry="14" fill="rgba(255,255,255,0.5)"/><path d="M40 36 Q70 20, 100 36 L96 44 Q70 32, 44 44Z" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><rect x="62" y="26" width="16" height="12" rx="2" fill="#fff" stroke="#E8A0D0" stroke-width="1.5"/><line x1="70" y1="28" x2="70" y2="36" stroke="#E8A0D0" stroke-width="2.5"/><line x1="66" y1="32" x2="74" y2="32" stroke="#E8A0D0" stroke-width="2.5"/><path d="M44 70 Q54 60, 64 70" fill="none" stroke="#1E1420" stroke-width="3" stroke-linecap="round"/><path d="M76 70 Q86 60, 96 70" fill="none" stroke="#1E1420" stroke-width="3" stroke-linecap="round"/><path d="M56 88 Q70 102, 84 88" fill="#C070A0" stroke="#1E1420" stroke-width="2.5" stroke-linecap="round"/><ellipse cx="70" cy="93" rx="5" ry="3.5" fill="#D88AB8"/><ellipse cx="38" cy="84" rx="10" ry="6" fill="rgba(244,150,200,0.5)"/><ellipse cx="102" cy="84" rx="10" ry="6" fill="rgba(244,150,200,0.5)"/><rect x="108" y="80" width="18" height="24" rx="3" fill="#F5EDE6" stroke="#D8D0C8" stroke-width="1.5" transform="rotate(8 117 92)"/><path d="M112 78 Q118 76, 116 84" fill="none" stroke="#DA90C2" stroke-width="4" stroke-linecap="round"/></g><text x="22" y="48" font-size="12" fill="#E8A0D0"><animate attributeName="y" values="48;10" dur="1.8s" fill="freeze"/><animate attributeName="opacity" values="1;0" dur="1.8s" fill="freeze"/>&#x2665;</text><text x="106" y="40" font-size="9" fill="#D48EBE"><animate attributeName="y" values="40;6" dur="2s" fill="freeze"/><animate attributeName="opacity" values="0.8;0" dur="2s" fill="freeze"/>&#x2665;</text><text x="14" y="36" font-size="11" fill="#E8A0D0" opacity="0.7">✦</text><text x="118" y="30" font-size="8" fill="#D48EBE" opacity="0.5">✦</text></svg>
        </div>
        <div style="flex:1;min-width:0"><div class="cc-name">Celly</div><div id="cc-msg"></div></div>
      </div>
      <div id="cc-ch"></div>
    </div>

    <!-- CALCULATOR -->
    <div class="sec"><div class="sec-t">Choose your plan</div>
    <div class="product">
      <div class="po" onclick="setProd('cb')">Cord Blood <span class="celly-tag" id="ct-cb"></span><div class="po-p">$725</div></div>
      <div class="po sel" onclick="setProd('cbt')">Blood & Tissue <span class="celly-tag" id="ct-cbt"></span><div class="po-p">$995</div></div>
    </div></div>
    <div class="sec"><div class="sec-t">Protection term</div><div class="list" id="plans">
      <div class="row" onclick="setPlan('annual',this)"><div class="row-l"><div class="dot"></div><div><div class="row-name">Pay year by year <span class="celly-tag" id="ct-annual"></span></div><div class="row-desc">Most flexible — renew annually</div></div></div><div class="row-r"><div class="row-price" id="pp-a">$995 + $400/yr</div></div></div>
      <div class="row sel" onclick="setPlan('18year',this)"><div class="row-l"><div class="dot"></div><div><div class="row-name">18-Year Prepaid <span class="celly-tag" id="ct-18year"></span></div><div class="row-desc">One payment, done</div></div></div><div class="row-r"><span class="badge badge-pop">Most popular</span><div class="row-price" id="pp-18">$6,665</div></div></div>
      <div class="row" onclick="setPlan('lifetime',this)"><div class="row-l"><div class="dot"></div><div><div class="row-name">Lifetime <span class="celly-tag" id="ct-lifetime"></span></div><div class="row-desc">Never pay for storage again</div></div></div><div class="row-r"><span class="badge badge-save" id="ps-l">Saving $4,600</span><div class="row-price" id="pp-l">$10,795</div></div></div>
    </div></div>
    <div class="sec"><div class="sec-t">Advanced protection</div><div class="list">
      <div class="tog" onclick="togAddon('pba',this)" id="a-pba"><div class="row-l"><div class="sw"></div><div><div class="row-name">Public Bank Access <span class="celly-tag" id="ct-pba"></span></div><div class="row-desc">Expanded cell access for your child</div></div></div><div class="row-price" id="ap-pba">FREE</div></div>
      <div class="tog" onclick="togAddon('pbaPlus',this)" id="a-pp"><div class="row-l"><div class="sw"></div><div><div class="row-name">Public Bank Access+ <span class="celly-tag" id="ct-pbaPlus"></span></div><div class="row-desc">Cord blood access for both parents</div></div></div><div class="row-price">$699</div></div>
      <div class="tog" onclick="togAddon('hla',this)" id="a-hla"><div class="row-l"><div class="sw"></div><div><div class="row-name">HLA Matching <span class="celly-tag" id="ct-hla"></span></div><div class="row-desc">Sibling compatibility testing</div></div></div><div class="row-price" id="ap-hla">$195</div></div>
      <div class="tog" onclick="togAddon('nga',this)" id="a-nga"><div class="row-l"><div class="sw"></div><div><div class="row-name">NGA <span class="celly-tag" id="ct-nga"></span></div><div class="row-desc">Newborn genetic analysis</div></div></div><div class="row-price">$399</div></div>
    </div></div>
    <button class="btn-next">Continue →</button>
  </div>
</div>

<div class="bottom">
  <div style="flex:1;display:flex;align-items:center;justify-content:space-between">
    <div><div class="fb-label">Your plan</div><div class="fb-total" id="total">–</div><div class="fb-save" id="save" style="display:none"></div></div>
    <div class="seg"><div class="seg-opt sel" onclick="setPaySched('full')">Pay in full</div><div class="seg-opt" onclick="setPaySched('6mo')">6 months</div><div class="seg-opt" onclick="setPaySched('12mo')">12 months</div></div>
  </div>
</div>

<script is:inline>
/* ═══ CALCULATOR ═══ */
const D={cb:{plans:{annual:{total:925,processing:725,storage:200,savings:0},'18year':{total:3560,savings:765},lifetime:{total:5625,savings:2300}}},cbt:{plans:{annual:{total:1395,processing:995,storage:400,savings:0},'18year':{total:6665,savings:1530},lifetime:{total:10795,savings:4600}}}};
const Ad={pba:299,pbaPlus:699,hla:295,hlaP:195,nga:399};
const f=n=>'$'+n.toLocaleString();
const S={product:'cbt',plan:'18year',addons:{},twins:false,interacted:false};

function setProd(v){S.product=v;S.interacted=true;document.querySelectorAll('.po').forEach((o,i)=>o.classList.toggle('sel',i===(v==='cb'?0:1)));upPrices();recalc();}
function setPlan(v,el){S.plan=v;S.interacted=true;if(el){el.parentElement.querySelectorAll('.row').forEach(o=>o.classList.remove('sel'));el.classList.add('sel');}upPrices();recalc();}
function togAddon(k,el){S.addons[k]=!S.addons[k];S.interacted=true;el.classList.toggle('sel');recalc();}
function upPrices(){const p=D[S.product].plans;document.getElementById('pp-a').textContent=f(p.annual.processing)+' + '+f(p.annual.storage)+'/yr';document.getElementById('pp-18').textContent=f(p['18year'].total);document.getElementById('pp-l').textContent=f(p.lifetime.total);document.getElementById('ps-l').textContent='Saving '+f(p.lifetime.savings);document.getElementById('ap-pba').textContent=S.product==='cbt'?'FREE':'$299';document.getElementById('ap-hla').textContent=S.plan!=='annual'?'$195':'$295';}
function recalc(){
  const m=S.twins?2:1;let t=D[S.product].plans[S.plan].total*m;let s=D[S.product].plans[S.plan].savings*m;const ip=S.plan!=='annual';
  Object.keys(S.addons).forEach(k=>{if(!S.addons[k])return;if(k==='pba'&&S.product==='cbt'){s+=299*m;}else if(k==='hla'){t+=(ip?Ad.hlaP:Ad.hla)*m;if(ip)s+=100*m;}else{t+=Ad[k]*m;}});
  if(!S.interacted){document.getElementById('total').textContent='\u2013';document.getElementById('save').style.display='none';}
  else{document.getElementById('total').textContent=f(t);const se=document.getElementById('save');if(s>0){se.style.display='block';se.textContent='Saving '+f(s);}else{se.style.display='none';}}
  window._t=t;window._s=s;}
recalc();
function setPaySched(v){S.paySched=v;document.querySelectorAll('.seg').forEach(seg=>{seg.querySelectorAll('.seg-opt').forEach((o,i)=>{o.classList.toggle('sel',['full','6mo','12mo'][i]===v);});});const t=window._t;if(v==='full')document.getElementById('total').textContent=f(t);else if(v==='6mo')document.getElementById('total').textContent=f(Math.ceil(t/6))+'/mo';else document.getElementById('total').textContent=f(Math.ceil(t/12))+'/mo';}

/* ═══ CELLY STATE MANAGEMENT ═══ */
function setCelly(state){
  document.querySelectorAll('#cc-av svg').forEach(el=>{
    const match=el.dataset.state===state;
    el.classList.toggle('off',!match);
  });
}

/* ═══ CELLY CHAT ═══ */
const QS=[
  {bot:"Let's build your plan! 4 quick questions.<br><br><strong>Do you have other children?</strong>",ch:[{id:'siblings',val:'first',t:'This is our first'},{id:'siblings',val:'yes',t:'Yes, we have other children'},{id:'siblings',val:'multiples',t:'Expecting twins or multiples'}]},
  {bot:a=>`${a.siblings==='first'?'Got it!':'Noted!'}<br><br><strong>Who do you want stem cell protection for?</strong>`,ch:[{id:'who',val:'baby',t:'Just my baby'},{id:'who',val:'extra',t:'My baby, with extra coverage for more conditions'},{id:'who',val:'parents',t:'My baby and both parents'}]},
  {bot:'<strong>What kinds of conditions do you want to be prepared for?</strong><span class="cc-edu">Cord blood treats blood and immune conditions. Cord tissue contains a different stem cell type (MSCs) being studied for neurological, orthopedic, and tissue repair therapies.</span>',ch:[{id:'conditions',val:'blood',t:'Blood and immune conditions'},{id:'conditions',val:'broad',t:'Blood, immune, and neurological or tissue-related'},{id:'conditions',val:'unsure',t:"I\u2019m not sure \u2014 what do you recommend?"}]},
  {bot:'<strong>Would you want to screen your baby for genetic health risks at birth?</strong><span class="cc-edu">Newborn genetic analysis can identify inherited conditions early \u2014 sometimes before symptoms appear.</span>',ch:[{id:'genetic',val:'yes',t:"Yes, I'd want to know early"},{id:'genetic',val:'maybe',t:"Maybe \u2014 I'd like to learn more"},{id:'genetic',val:'no',t:'No, not interested'}]}
];
const LBL={'siblings:first':'First child','siblings:yes':'Other children','siblings:multiples':'Twins/multiples','who:baby':'Just my baby','who:extra':'Extra coverage','who:parents':'Baby + both parents','conditions:blood':'Blood & immune','conditions:broad':'Broad coverage','conditions:unsure':'Not sure','genetic:yes':'Screen early','genetic:maybe':'Maybe','genetic:no':'No'};
let cA={},cStep=0;
const cMsg=document.getElementById('cc-msg'),cCh=document.getElementById('cc-ch');

function startCelly(){
  document.getElementById('celly-banner').style.display='none';
  document.getElementById('celly-chat').classList.add('open');
  setCelly('idle');
  cStep=0;showCQ(0);
}
function closeCelly(){
  document.getElementById('celly-chat').classList.remove('open');
  document.getElementById('celly-banner').style.display='flex';
}
function showCQ(s){const q=QS[s];const bot=typeof q.bot==='function'?q.bot(cA):q.bot;cMsg.innerHTML=`<div class="cc-bubble">${bot}</div>`;cCh.innerHTML=`<div class="cc-choices">${q.ch.map(c=>`<button class="cc-choice" onclick="cPick('${c.id}','${c.val}')">${c.t}</button>`).join('')}</div>`;}

function cPick(k,v){
  cA[k]=v;cStep++;
  cMsg.innerHTML+=`<div class="cc-user"><div class="cc-user-bub">${LBL[k+':'+v]||v}</div></div>`;
  cCh.innerHTML='';
  setCelly('idle'); // brief nod implied

  if(k==='conditions'&&v==='unsure'){showCellyResponse("I'd go with <strong>cord blood & tissue</strong> \u2014 it gives you two types of stem cells instead of one, covering blood, immune, <em>and</em> neurological/tissue conditions. Plus, Public Bank Access is included free with it. I'll set that up for you!");return;}
  if(k==='genetic'&&v==='maybe'){showCellyResponse("NGA screens your baby's cord blood for inherited genetic conditions at birth \u2014 things like metabolic disorders or immune deficiencies, sometimes before symptoms ever show up. It's $399 and totally optional. I'll flag it for you so you can decide!");return;}
  setTimeout(()=>advanceQ(),400);
}

function showCellyResponse(msg){
  setTimeout(()=>{
    cMsg.querySelectorAll('.cc-bubble,.cc-user').forEach(b=>b.classList.add('out'));
    setTimeout(()=>{
      setCelly('writing');
      cMsg.innerHTML=`<div class="cc-typing"><div class="cc-dot"></div><div class="cc-dot"></div><div class="cc-dot"></div></div>`;
      setTimeout(()=>{
        setCelly('idle');
        cMsg.innerHTML=`<div class="cc-bubble">${msg}</div>`;
        setTimeout(()=>{
          setCelly('writing');
          cMsg.innerHTML+=`<div class="cc-typing" style="margin-top:8px"><div class="cc-dot"></div><div class="cc-dot"></div><div class="cc-dot"></div></div>`;
          setTimeout(()=>{
            cMsg.querySelectorAll('.cc-typing').forEach(t=>t.remove());
            setCelly('idle');
            if(cStep<QS.length){
              const q=QS[cStep];const bot=typeof q.bot==='function'?q.bot(cA):q.bot;
              cMsg.innerHTML+=`<div class="cc-bubble" style="margin-top:8px">${bot}</div>`;
              cCh.innerHTML=`<div class="cc-choices">${q.ch.map(c=>`<button class="cc-choice" onclick="cPick('${c.id}','${c.val}')">${c.t}</button>`).join('')}</div>`;
            } else {applyCelly();}
          },400+Math.random()*300);
        },2000);
      },600);
    },250);
  },400);
}

function advanceQ(){
  cMsg.querySelectorAll('.cc-bubble,.cc-user').forEach(b=>b.classList.add('out'));
  setTimeout(()=>{
    setCelly('writing');
    cMsg.innerHTML=`<div class="cc-typing"><div class="cc-dot"></div><div class="cc-dot"></div><div class="cc-dot"></div></div>`;
    setTimeout(()=>{
      setCelly('idle');
      if(cStep<QS.length)showCQ(cStep);else applyCelly();
    },400+Math.random()*300);
  },250);
}

function applyCelly(){
  setCelly('happy');
  cMsg.innerHTML=`<div class="cc-bubble">All set! \ud83c\udf89 I've configured your plan below. Adjust anything you like!</div>`;
  cCh.innerHTML=`<button class="cc-close" onclick="closeCelly()">Close</button>`;
  S.interacted=true;
  document.querySelectorAll('.celly-tag').forEach(t=>{t.className='celly-tag';t.innerHTML='';});

  // Determine picks
  const prodKey=cA.conditions==='broad'||cA.conditions==='unsure'?'cbt':'cb';

  // Staggered bounce animation as Celly applies picks
  const DELAY=350;
  let step=0;

  // 1. Product
  setTimeout(()=>{
    setProd(prodKey);
    const prodEl=document.querySelectorAll('.po')[prodKey==='cb'?0:1];
    prodEl.classList.add('pop-bounce');
    setTimeout(()=>prodEl.classList.remove('pop-bounce'),500);
    const prodReason=prodKey==='cbt'?"You wanted coverage for neurological and tissue conditions too \u2014 cord tissue adds a second type of stem cell.":"You chose to focus on blood and immune conditions \u2014 cord blood covers that.";
    setTag('ct-'+prodKey,'pick',"Celly's pick",prodReason);
  },DELAY*(step++));

  // 2. Plan (always 18year, no tag)
  setTimeout(()=>{
    const planEl=document.querySelectorAll('#plans .row')[1];
    setPlan('18year',planEl);
  },DELAY*(step++));

  // 3. Addons
  ['pba','pbaPlus','hla','nga'].forEach(k=>{S.addons[k]=false;document.getElementById('a-'+(k==='pbaPlus'?'pp':k)).classList.remove('sel');});

  if(cA.who==='extra'||cA.who==='parents'){
    setTimeout(()=>{
      S.addons.pba=true;const el=document.getElementById('a-pba');el.classList.add('sel');
      el.classList.add('pop-bounce');setTimeout(()=>el.classList.remove('pop-bounce'),500);
      setTag('ct-pba','pick',"Celly's pick","You wanted extra coverage for more conditions \u2014 PBA gives your child access to additional matching stem cells.");
      recalc();
    },DELAY*(step++));
  }
  if(cA.who==='parents'){
    setTimeout(()=>{
      S.addons.pbaPlus=true;const el=document.getElementById('a-pp');el.classList.add('sel');
      el.classList.add('pop-bounce');setTimeout(()=>el.classList.remove('pop-bounce'),500);
      setTag('ct-pbaPlus','pick',"Celly's pick","You wanted coverage for both parents \u2014 PBA+ gives them access to cord blood treatments too.");
      recalc();
    },DELAY*(step++));
  }
  if(cA.siblings==='yes'||cA.siblings==='multiples'){
    setTimeout(()=>{
      S.addons.hla=true;const el=document.getElementById('a-hla');el.classList.add('sel');
      el.classList.add('pop-bounce');setTimeout(()=>el.classList.remove('pop-bounce'),500);
      setTag('ct-hla','pick',"Celly's pick","You have other children \u2014 HLA matching checks if your baby's cord blood is compatible with siblings.");
      recalc();
    },DELAY*(step++));
  }
  if(cA.genetic==='yes'){
    setTimeout(()=>{
      S.addons.nga=true;const el=document.getElementById('a-nga');el.classList.add('sel');
      el.classList.add('pop-bounce');setTimeout(()=>el.classList.remove('pop-bounce'),500);
      setTag('ct-nga','pick',"Celly's pick","You said you'd want to know about genetic health risks as early as possible.");
      recalc();
    },DELAY*(step++));
  } else if(cA.genetic==='maybe'){
    setTimeout(()=>{
      setTag('ct-nga','suggest',"Celly suggests","You were interested in learning more \u2014 NGA screens for inherited conditions at birth. Optional but worth considering.");
    },DELAY*(step++));
  }

  // Final recalc after all staggered
  setTimeout(()=>{
    recalc();
    setCelly('idle');
  },DELAY*(step+1));
}
function setTag(id,cls,label,reason){const t=document.getElementById(id);t.className='celly-tag '+cls;t.innerHTML=label+'<span class="ct-q">?</span><span class="ct-tip">'+reason+'</span>';}
</script>

</BaseLayout>

