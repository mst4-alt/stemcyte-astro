<script>
  function setupAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;

          // Bar fills: animate width
          if (el.classList.contains('pub-bar-group')) {
            const fills = el.querySelectorAll('.pub-bar-fill');
            fills.forEach((fill, i) => {
              setTimeout(() => {
                const target = fill.dataset.targetWidth || '0%';
                fill.style.width = target;
              }, i * 200);
            });
          }

          // Big number: fade in
          if (el.classList.contains('big-num')) {
            el.classList.add('animated');
          }

          // Stat strip numbers: staggered fade in with count-up
          if (el.classList.contains('pub-stat-strip')) {
            const nums = el.querySelectorAll('.pub-stat-num');
            nums.forEach((num, i) => {
              setTimeout(() => {
                num.classList.add('animated');
                const target = parseInt(num.textContent);
                if (!isNaN(target) && target > 0) {
                  let current = 0;
                  const duration = 800;
                  const steps = 30;
                  const increment = target / steps;
                  const stepTime = duration / steps;
                  const counter = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                      num.textContent = target;
                      clearInterval(counter);
                    } else {
                      num.textContent = Math.floor(current);
                    }
                  }, stepTime);
                }
              }, i * 150);
            });
          }

          observer.unobserve(el);
        }
      });
    }, { threshold: 0.3 });

    const barGroup = document.querySelector('.pub-bar-group');
    if (barGroup) observer.observe(barGroup);

    const bigNum = document.querySelector('.big-num');
    if (bigNum) observer.observe(bigNum);

    const statStrip = document.querySelector('.pub-stat-strip');
    if (statStrip) observer.observe(statStrip);
  }

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    setupAnimations();
  } else {
    document.querySelectorAll('.pub-bar-fill').forEach(fill => {
      fill.style.width = fill.dataset.targetWidth || '0%';
    });
    document.querySelectorAll('.big-num, .pub-stat-num').forEach(el => {
      el.classList.add('animated');
    });
  }
</script>

