      </a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="ci-cta">
  <h2>Medical information inquiries</h2>
  <p>For product information, clinical data requests, or medical affairs inquiries, contact our team.</p>
  <a href="/biologics/contact" class="btn">Contact Medical Affairs</a>
  <p class="sec-text">For patient-facing cord blood banking, visit <a href="/">stemcyte.com</a></p>
</section>

<script>
(function() {
  // Respect prefers-reduced-motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const canvas = document.getElementById('ciGridCanvas');
    if (canvas) {
      canvas.style.display = 'none';
      const fallback = document.createElement('div');
      fallback.className = 'ci-grid-static';
      canvas.parentElement.insertBefore(fallback, canvas);
    }
    return;
  }

  const canvas = document.getElementById('ciGridCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const GRID = 64;
  const GRID_ALPHA = 0.045;
  const PULSE_ALPHA = 0.50;
  const PULSE_COUNT = 35;
  const SPEED_MIN = 0.6;
  const SPEED_MAX = 1.2;
  const SPAWN_RATE = 0.14;
  const LEN_MIN = 60;
  const LEN_MAX = 90;

  let W = 0, H = 0;
  const pulses = [];

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = rect.width;
    H = rect.height;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    // Don't set style.width/height — let inset:0 handle sizing
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function spawnPulse(scatter) {
    const horizontal = Math.random() > 0.45;
    const speed = SPEED_MIN + Math.random() * (SPEED_MAX - SPEED_MIN);
    const len = LEN_MIN + Math.random() * (LEN_MAX - LEN_MIN);

    if (horizontal) {
      const row = Math.floor(Math.random() * Math.ceil(H / GRID)) * GRID;
      pulses.push({
        x: scatter ? Math.random() * W : -len - 10,
        y: row, dx: speed, dy: 0, len: len, horiz: true
      });
    } else {
      const col = Math.floor(Math.random() * Math.ceil(W / GRID)) * GRID;
      pulses.push({
        x: col,
        y: scatter ? Math.random() * H : -len - 10,
        dx: 0, dy: speed * 0.8, len: len, horiz: false
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Draw static grid lines
    ctx.strokeStyle = 'rgba(255,255,255,' + GRID_ALPHA + ')';
    ctx.lineWidth = 1;
    for (var x = 0; x <= W; x += GRID) {
      ctx.beginPath();
      ctx.moveTo(x + 0.5, 0);
      ctx.lineTo(x + 0.5, H);
      ctx.stroke();
    }
    for (var y = 0; y <= H; y += GRID) {
      ctx.beginPath();
      ctx.moveTo(0, y + 0.5);
      ctx.lineTo(W, y + 0.5);
      ctx.stroke();
    }

    // Draw and update pulses
    for (var i = pulses.length - 1; i >= 0; i--) {
      var p = pulses[i];
      p.x += p.dx;
      p.y += p.dy;

      var grad;
      if (p.horiz) {
        grad = ctx.createLinearGradient(p.x - p.len, p.y, p.x, p.y);
      } else {
        grad = ctx.createLinearGradient(p.x, p.y - p.len, p.x, p.y);
      }

      grad.addColorStop(0, 'rgba(79,163,184,0)');
      grad.addColorStop(0.4, 'rgba(79,163,184,' + (PULSE_ALPHA * 0.4) + ')');
      grad.addColorStop(0.85, 'rgba(79,163,184,' + PULSE_ALPHA + ')');
      grad.addColorStop(1, 'rgba(120,195,210,' + (PULSE_ALPHA * 0.5) + ')');

      ctx.strokeStyle = grad;
      ctx.lineWidth = 1;
      ctx.beginPath();
      if (p.horiz) {
        ctx.moveTo(p.x - p.len, p.y + 0.5);
        ctx.lineTo(p.x, p.y + 0.5);
      } else {
        ctx.moveTo(p.x + 0.5, p.y - p.len);
        ctx.lineTo(p.x + 0.5, p.y);
      }
      ctx.stroke();

      // Remove if off screen
      if (p.horiz && p.x - p.len > W + 20) {
        pulses.splice(i, 1);
      } else if (!p.horiz && p.y - p.len > H + 20) {
        pulses.splice(i, 1);
      }
    }

    // Spawn new pulses
    if (pulses.length < PULSE_COUNT && Math.random() < SPAWN_RATE) {
      spawnPulse(false);
    }

    requestAnimationFrame(draw);
  }

  // Initialize
  resize();
  window.addEventListener('resize', resize);

  // Seed initial pulses scattered across the grid
  for (var i = 0; i < Math.floor(PULSE_COUNT * 0.6); i++) {
    spawnPulse(true);
  }

  draw();
})();
</script>

</BaseLayout>
