.lc-hero h1 { font-family:'Playfair Display',serif; font-size:42px; font-weight:400; line-height:1.08; letter-spacing:-1px; color:#fff; margin-bottom:12px; }
.lc-hero h1 .sub { display:block; font-size:22px; color:#E8A0D0; margin-top:4px; font-family:'Lato',sans-serif; font-weight:400; }
