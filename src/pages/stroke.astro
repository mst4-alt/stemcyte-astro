---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalStudy",
  "name": "Cord blood cell therapy for acute ischemic stroke",
  "description": "Phase I clinical trial of allogeneic human umbilical cord blood mononuclear cells for acute ischemic stroke, with Phase II approved by FDA and TFDA.",
  "studySubject": { "@type": "MedicalCondition", "name": "Acute Ischemic Stroke" },
  "sponsor": { "@type": "Organization", "name": "StemCyte, Inc." },
  "status": "Completed",
  "identifier": "NCT02433509"
};
---

<BaseLayout title="Acute Ischemic Stroke Clinical Trial" description="Phase I trial results: A patient paralyzed by acute ischemic stroke regained complete motor function after cord blood cell therapy. Published in Cell Transplantation and Tzu Chi Medical Journal." schema={schema} noindex={true}>

<style is:global>

