---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Expanded Access Program",
  "description": "StemCyte's compassionate use framework for investigational therapies.",
  "publisher": { "@type": "Organization", "name": "StemCyte, Inc." }
};
---

<BaseLayout title="Expanded Access Program | StemCyte" description="StemCyte's Expanded Access (compassionate use) program for REGENECYTE® (HPC, Cord Blood)." schema={schema}>

<style is:global>

/* HERO */
.eap-hero { background:linear-gradient(180deg,#1a0820 0%,#2d1038 40%,#3D0F31 100%); padding:140px 48px 64px; position:relative; overflow:hidden; }
.eap-hero::after { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 60% 80%, rgba(108,26,85,0.25) 0%, transparent 60%); pointer-events:none; }
.eap-hero-inner { max-width:960px; margin:0 auto; position:relative; z-index:2; display:flex; justify-content:space-between; align-items:flex-end; gap:40px; }
.eap-hero-left .overline { font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#E8A0D0; margin-bottom:14px; display:inline-flex; align-items:center; gap:8px; }
.eap-hero-left .overline .dot { width:6px; height:6px; border-radius:50%; background:#E8A0D0; animation:eap-pulse 2s ease infinite; }
@keyframes eap-pulse { 0%,100%{box-shadow:0 0 0 0 rgba(232,160,208,0.4)} 50%{box-shadow:0 0 0 8px rgba(232,160,208,0)} }
.eap-hero h1 { font-family:'Playfair Display',serif; font-size:44px; font-weight:400; line-height:1.1; letter-spacing:-1.5px; color:#fff; margin-bottom:14px; }
.eap-hero .subtitle { font-size:17px; color:rgba(255,255,255,0.6); line-height:1.7; max-width:440px; }
.eap-hero-cta { flex-shrink:0; text-align:center; padding:24px 32px; background:rgba(255,255,255,0.06); border-radius:14px; border:1px solid rgba(255,255,255,0.08); }
.eap-hero-cta .fc-label { font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#E8A0D0; margin-bottom:6px; }
.eap-hero-cta h3 { font-size:16px; font-weight:700; color:#fff; margin-bottom:12px; }
.eap-hero-cta .pill-btn { display:inline-flex; align-items:center; gap:8px; background:#6C1A55; color:#fff; padding:10px 24px; border-radius:100px; font-size:13px; font-weight:700; text-decoration:none; transition:background 0.25s; }
.eap-hero-cta .pill-btn:hover { background:#8B3572; }
.eap-hero-cta .pill-btn svg { width:16px; height:16px; }

/* BANDS */
.eap-band { padding:56px 48px; }
.eap-band-in { max-width:960px; margin:0 auto; }
.eap-band.cream { background:#FAF9F7; }
.eap-band.elig { background:#F4F0F5; }
.eap-sl { font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6C1A55; margin-bottom:8px; }
.eap-sh { font-family:'Playfair Display',serif; font-size:26px; font-weight:400; letter-spacing:-0.3px; color:#2C2A26; margin-bottom:16px; line-height:1.25; }
.eap-sp { font-size:15px; line-height:1.8; color:#5A564E; margin-bottom:14px; }

/* OVERVIEW 2-COL */
.eap-overview { display:grid; grid-template-columns:1fr 1fr; gap:28px; align-items:start; }
.eap-ind { background:linear-gradient(135deg, #FBF5F9 0%, #F3F0F8 100%); border:1px solid #E8A0D0; border-radius:12px; padding:28px; position:relative; overflow:hidden; }
.eap-ind::before { content:''; position:absolute; top:0; left:0; width:4px; height:100%; background:#6C1A55; }
.eap-ind .il { font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6C1A55; margin-bottom:6px; }
.eap-ind h3 { font-size:18px; font-weight:700; color:#2C2A26; margin-bottom:6px; }
.eap-ind p { font-size:14px; color:#5A564E; line-height:1.6; margin:0; }
.eap-ind a { display:inline-flex; align-items:center; gap:4px; font-size:13px; font-weight:700; color:#6C1A55; text-decoration:none; margin-top:10px; transition:color 0.2s; }
.eap-ind a:hover { color:#8B2E72; }

/* ACCORDION */
.eap-acc { border:1px solid #E8E2DC; border-radius:12px; overflow:hidden; margin-bottom:8px; }
.eap-acc:last-child { margin-bottom:0; }
.eap-acc-head { display:flex; align-items:center; justify-content:space-between; padding:16px 24px; cursor:pointer; background:rgba(255,255,255,0.7); transition:background 0.2s; user-select:none; }
.eap-acc-head:hover { background:rgba(255,255,255,0.9); }
.eap-acc-head h4 { font-size:15px; font-weight:700; color:#2C2A26; display:flex; align-items:center; gap:10px; }
.eap-acc-head h4 .ico { width:28px; height:28px; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.eap-acc-head h4 .ico svg { width:14px; height:14px; }
.eap-acc-head .chev { width:18px; height:18px; color:#8A857A; transition:transform 0.35s ease; }
.eap-acc.open .eap-acc-head .chev { transform:rotate(180deg); }
.eap-acc-body { overflow:hidden; transition:height 0.35s ease; }
.eap-acc-inner { padding:4px 24px 20px; }
.eap-ni { display:flex; gap:10px; padding:7px 0; align-items:flex-start; }
.eap-nn { width:20px; height:20px; border-radius:50%; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px; }
.eap-nn.plum { background:rgba(108,26,85,0.08); color:#6C1A55; }
.eap-nn.green { background:rgba(61,139,106,0.08); color:#3D8B6A; }
.eap-nn.blue { background:rgba(59,109,196,0.08); color:#3B6DC4; }
.eap-ni p { font-size:13px; color:#5A564E; line-height:1.55; margin:0; }

/* PIPELINE */
.eap-pipe { display:flex; align-items:flex-start; gap:0; margin-top:24px; position:relative; }
.eap-pipe::before { content:''; position:absolute; top:18px; left:24px; right:24px; height:2px; background:linear-gradient(90deg,#6C1A55,#D4649A,#E8A0D0); }
.eap-pipe .ps { flex:1; text-align:center; position:relative; z-index:1; }
.eap-pipe .ps .pn { width:36px; height:36px; border-radius:50%; color:#fff; font-family:'Source Serif 4',serif; font-size:15px; font-weight:600; display:inline-flex; align-items:center; justify-content:center; margin-bottom:12px; }
.eap-pipe .ps:nth-child(1) .pn { background:#6C1A55; box-shadow:0 2px 8px rgba(108,26,85,0.25); }
.eap-pipe .ps:nth-child(2) .pn { background:#8B3572; box-shadow:0 2px 8px rgba(139,53,114,0.2); }
.eap-pipe .ps:nth-child(3) .pn { background:#B74E8A; box-shadow:0 2px 8px rgba(183,78,138,0.2); }
.eap-pipe .ps:nth-child(4) .pn { background:#D4649A; box-shadow:0 2px 8px rgba(212,100,154,0.2); }
.eap-pipe .ps h4 { font-size:13px; font-weight:700; color:#2C2A26; margin-bottom:4px; }
.eap-pipe .ps p { font-size:12px; color:#6B6760; line-height:1.4; margin:0; padding:0 8px; }

/* LEGAL */
.eap-legal { padding:24px 28px; background:#F5F2ED; border-radius:12px; max-width:960px; margin:0 auto; }
.eap-legal p { font-size:13px; color:#6B6760; line-height:1.7; margin:0; }
.eap-legal-band { padding:0 48px 56px; background:#FAF9F7; }

/* CTA BANNER */
.eap-cta-banner { background:linear-gradient(160deg,#6C1A55,#3D0F31); padding:48px; text-align:center; }
.eap-cta-banner h2 { font-family:'Playfair Display',serif; font-size:32px; font-weight:400; color:#fff; margin-bottom:8px; letter-spacing:-0.5px; }
.eap-cta-banner .cta-sub { font-size:16px; color:rgba(255,255,255,0.6); margin-bottom:28px; max-width:480px; margin-left:auto; margin-right:auto; line-height:1.7; }
.eap-cta-banner .pill-btn { display:inline-flex; align-items:center; gap:8px; background:#fff; color:#6C1A55; padding:14px 32px; border-radius:100px; font-size:15px; font-weight:700; text-decoration:none; transition:all 0.25s; }
.eap-cta-banner .pill-btn:hover { background:rgba(255,255,255,0.85); }
.eap-cta-banner .pill-btn svg { width:18px; height:18px; }
.eap-cta-banner .note { font-size:13px; color:rgba(255,255,255,0.45); margin-top:14px; }

/* RESPONSIVE */
@media (max-width:900px) {
  .eap-hero { padding:120px 24px 48px; }
  .eap-hero h1 { font-size:32px; }
  .eap-hero-inner { flex-direction:column; align-items:flex-start; }
  .eap-band, .eap-legal-band { padding-left:24px; padding-right:24px; }
  .eap-overview { grid-template-columns:1fr; }
  .eap-pipe { flex-direction:column; gap:16px; align-items:center; }
  .eap-pipe::before { display:none; }
  .eap-cta-banner { padding:40px 24px; }
  .eap-cta-banner h2 { font-size:28px; }
}
@media (max-width:600px) {
  .eap-hero { padding:110px 20px 40px; }
  .eap-hero h1 { font-size:28px; }
  .eap-hero .subtitle { font-size:15px; }
  .eap-band { padding:40px 20px; }
  .eap-acc-head { padding:14px 20px; }
  .eap-acc-inner { padding:4px 20px 16px; }
  .eap-cta-banner { padding:36px 20px; }
  .eap-cta-banner h2 { font-size:24px; }
}

</style>

<!-- HERO -->
<section id="hero">
<div class="eap-hero">
  <div class="eap-hero-inner">
    <div class="eap-hero-left">
      <div class="overline"><span class="dot"></span> EXPANDED ACCESS</div>
      <h1>Expanded Access Program</h1>
      <p class="subtitle">StemCyte&rsquo;s compassionate use framework for investigational therapies.</p>
    </div>
    <div class="eap-hero-cta">
      <div class="fc-label">Physician Inquiry</div>
      <h3>Request access</h3>
      <a class="pill-btn" href="mailto:expandedaccess@stemcyte.com">
        <svg viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="10" rx="2" stroke="#fff" stroke-width="1.5"/><path d="M2 6l7 4.5L16 6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Email clinical team
      </a>
    </div>
  </div>
</div>
</section>

<!-- BACKGROUND -->
<div class="eap-band cream">
  <div class="eap-band-in">
    <div class="eap-overview">
      <div>
        <div class="eap-sl">Background</div>
        <div class="eap-sh">What is expanded access?</div>
        <p class="eap-sp">Expanded access (compassionate use) allows patients with serious or life-threatening conditions to receive investigational therapies outside clinical trials when no comparable treatment exists.</p>
        <p class="eap-sp">StemCyte&rsquo;s program covers three pathways &mdash; EAP, emergency IND, and single patient access &mdash; each evaluated individually per FDA regulations.</p>
      </div>
      <div class="eap-ind">
        <div class="il">Active Indication</div>
        <h3>Long COVID</h3>
        <p>85% fatigue resolution in Phase IIa (vs. 20% placebo). For patients who cannot join Phase III trials.</p>
        <a href="https://clinicaltrials.gov/study/NCT07332338" target="_blank" rel="noopener">
          ClinicalTrials.gov &rarr;
        </a>
      </div>
    </div>
  </div>
</div>

<!-- ELIGIBILITY — Accordion -->
<div class="eap-band elig">
  <div class="eap-band-in">
    <div class="eap-sl">Eligibility</div>
    <div class="eap-sh">Who qualifies?</div>

    <!-- Patient (open by default) -->
    <div class="eap-acc open" data-acc>
      <div class="eap-acc-head" onclick="eapToggle(this.parentElement)">
        <h4><span class="ico" style="background:rgba(108,26,85,0.08)"><svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="7" r="4" stroke="#6C1A55" stroke-width="1.5"/><path d="M3 18c0-3.87 3.13-7 7-7s7 3.13 7 7" stroke="#6C1A55" stroke-width="1.5" stroke-linecap="round"/></svg></span> Patient</h4>
        <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="eap-acc-body">
        <div class="eap-acc-inner">
          <div class="eap-ni"><div class="eap-nn plum">1</div><p>Has a serious or life-threatening condition with no satisfactory alternative treatment</p></div>
          <div class="eap-ni"><div class="eap-nn plum">2</div><p>Is ineligible for any ongoing clinical study of the product, including due to geographic limitations</p></div>
          <div class="eap-ni"><div class="eap-nn plum">3</div><p>Has not received any cell-based therapy within the past 12 months</p></div>
          <div class="eap-ni"><div class="eap-nn plum">4</div><p>Clinical assessment determines that potential benefits outweigh the risks</p></div>
          <div class="eap-ni"><div class="eap-nn plum">5</div><p>Agrees to comply with all study requirements and complete all scheduled visits</p></div>
        </div>
      </div>
    </div>

    <!-- Product (closed) -->
    <div class="eap-acc" data-acc>
      <div class="eap-acc-head" onclick="eapToggle(this.parentElement)">
        <h4><span class="ico" style="background:rgba(61,139,106,0.08)"><svg viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="3" stroke="#3D8B6A" stroke-width="1.5"/><path d="M10 7v6M7 10h6" stroke="#3D8B6A" stroke-width="1.5" stroke-linecap="round"/></svg></span> Product</h4>
        <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="eap-acc-body">
        <div class="eap-acc-inner">
          <div class="eap-ni"><div class="eap-nn green">1</div><p>Is under clinical investigation in one or more trials with high safety profiles</p></div>
          <div class="eap-ni"><div class="eap-nn green">2</div><p>StemCyte has adequate supply to support expanded access</p></div>
          <div class="eap-ni"><div class="eap-nn green">3</div><p>Providing access will not interfere with completing clinical trials or delay marketing approval</p></div>
        </div>
      </div>
    </div>

    <!-- Physician (closed) -->
    <div class="eap-acc" data-acc>
      <div class="eap-acc-head" onclick="eapToggle(this.parentElement)">
        <h4><span class="ico" style="background:rgba(59,109,196,0.08)"><svg viewBox="0 0 20 20" fill="none"><path d="M10 2l2 4 4.5.7-3.3 3.2.8 4.5L10 12.3 5.9 14.4l.8-4.5L3.5 6.7 8 6z" stroke="#3B6DC4" stroke-width="1.5" stroke-linejoin="round"/></svg></span> Physician</h4>
        <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="eap-acc-body">
        <div class="eap-acc-inner">
          <div class="eap-ni"><div class="eap-nn blue">1</div><p>Must be properly licensed in their jurisdiction</p></div>
          <div class="eap-ni"><div class="eap-nn blue">2</div><p>Must meet all applicable country-specific legal and regulatory requirements</p></div>
          <div class="eap-ni"><div class="eap-nn blue">3</div><p>Must be qualified and experienced in cord blood or stem cell infusion</p></div>
          <div class="eap-ni"><div class="eap-nn blue">4</div><p>Must agree in writing to comply with safety reporting and IP protection requirements</p></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- PROCESS -->
<div class="eap-band cream">
  <div class="eap-band-in">
    <div class="eap-sl">Process</div>
    <div class="eap-sh">How to request access</div>
    <p class="eap-sp" style="margin-bottom:0">Requests are always initiated by the treating physician.</p>
    <div class="eap-pipe">
      <div class="ps"><div class="pn">1</div><h4>Contact</h4><p>Physician emails clinical team with patient details</p></div>
      <div class="ps"><div class="pn">2</div><h4>Acknowledge</h4><p>Receipt confirmed within 10 business days</p></div>
      <div class="ps"><div class="pn">3</div><h4>Evaluate</h4><p>Case-by-case review per FDA regulations</p></div>
      <div class="ps"><div class="pn">4</div><h4>Coordinate</h4><p>Delivery via appropriate pathway</p></div>
    </div>
  </div>
</div>

<!-- LEGAL -->
<div class="eap-legal-band">
  <div class="eap-legal">
    <p>As authorized by the 21st Century Cures Act, StemCyte may revise this expanded access program at any time. The posting of this program shall not serve as a guarantee of access to any specific investigational drug by any individual patient. Expanded access is subject to FDA regulations and is evaluated on a case-by-case basis. Clinical outcomes are not guaranteed.</p>
  </div>
</div>

<!-- CTA BANNER -->
<section class="eap-cta-banner">
  <h2>Expanded Access Inquiry</h2>
  <p class="cta-sub">Treating physicians may submit expanded access questions and requests directly to StemCyte&rsquo;s clinical team.</p>
  <a class="pill-btn" href="mailto:expandedaccess@stemcyte.com">
    <svg viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 6l7 4.5L16 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    expandedaccess@stemcyte.com
  </a>
  <p class="note">Requests are typically acknowledged within 10 business days.</p>
</section>

<script>
function eapToggle(el) {
  const allAcc = document.querySelectorAll('[data-acc]');
  const isOpen = el.classList.contains('open');
  allAcc.forEach(acc => {
    if (acc !== el || isOpen) eapClose(acc);
  });
  if (!isOpen) eapOpen(el);
}
function eapOpen(acc) {
  const body = acc.querySelector('.eap-acc-body');
  const inner = acc.querySelector('.eap-acc-inner');
  acc.classList.add('open');
  body.style.height = inner.offsetHeight + 'px';
  body.addEventListener('transitionend', function handler() {
    body.style.height = 'auto';
    body.removeEventListener('transitionend', handler);
  });
}
function eapClose(acc) {
  const body = acc.querySelector('.eap-acc-body');
  if (!acc.classList.contains('open')) return;
  body.style.height = body.scrollHeight + 'px';
  body.offsetHeight;
  body.style.height = '0px';
  acc.classList.remove('open');
}
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.eap-acc.open').forEach(acc => {
    const body = acc.querySelector('.eap-acc-body');
    const inner = acc.querySelector('.eap-acc-inner');
    body.style.height = inner.offsetHeight + 'px';
    requestAnimationFrame(() => { body.style.height = 'auto'; });
  });
  document.querySelectorAll('.eap-acc:not(.open)').forEach(acc => {
    acc.querySelector('.eap-acc-body').style.height = '0px';
  });
});
</script>

</BaseLayout>
