---
import BaseLayout from '../layouts/BaseLayout.astro';
import Accordion from '../components/islands/Accordion.jsx';

const faqData = [
  {
    category: 'About cord blood banking',
    items: [
      { q: 'What is cord blood banking?', a: "Cord blood banking preserves the stem cells found in your baby's umbilical cord blood after birth. These stem cells can treat over 80 diseases including cancers, blood disorders, and immune system disorders. Your newborn's stem cells can only be collected immediately after birth." },
      { q: 'Should I bank both cord blood and cord tissue?', a: "Yes! — they contain different types of stem cells with different applications. Cord blood contains hematopoietic stem cells (HSCs) that regenerate blood and immune systems, used in over 60,000 transplants since 1988. Cord tissue contains mesenchymal stem cells (MSCs) being researched in over 500 clinical trials for regenerative medicine including heart disease, Alzheimer's, and osteoarthritis. Banking both provides the most comprehensive protection." },
      { q: 'What diseases can cord blood stem cells treat?', a: 'Cord blood stem cells are used to treat over 80 diseases including leukemia, lymphoma, sickle cell disease, thalassemia, severe combined immunodeficiency (SCID), and metabolic disorders like Krabbe disease. Clinical trials are underway for cerebral palsy, autism, type 1 diabetes, stroke, and more.' },
      { q: "Is cord blood medical waste if I don't bank it?", a: "Yes! If your baby's cord blood stem cells are not collected at birth, they are discarded as medical waste. This is a one-time opportunity — there is no way to go back and collect them later." },
      { q: 'Can stored cord blood be used for treating anyone in a family?', a: "Your baby's cord blood is a 100% match for themselves. Biological siblings have a 75% chance of being a partial HLA match, and biological parents have about a 20% probability of being a partial match. Each cord blood unit can only be used in one transplant — once used, it is no longer available for other family members." },
      { q: "Should I bank each child's cord blood?", a: "Yes! Each child's cord blood is unique to them and is the only way to guarantee a 100% match. Physicians use an entire sample in each transplant since more stem cells increase the engraftment rate and overall success. Each cord blood unit can only be used once." },
    ],
  },
  {
    category: 'About the process',
    items: [
      { q: 'Is the collection process safe?', a: 'Completely safe. Cord blood is collected after the baby is born and the umbilical cord has been clamped and cut. No blood is taken from the baby or mother. It does not interfere with the delivery process in any way.' },
      { q: 'Can I do delayed cord clamping and still bank?', a: 'Yes! While delayed cord clamping may reduce the volume of cord blood collected, a good amount of stem cells can still be collected and preserved. Many families choose to do both. Discuss with your OB to include both in your birth plan.' },
      { q: 'What if I deliver early or unexpectedly?', a: 'Call us immediately at (866) 389-4659. Overnight kit shipping is available for $50. Our team can coordinate urgent delivery to most hospitals within 24 hours.' },
      { q: 'How long can cord blood be stored?', a: 'Research indicates that properly cryopreserved cord blood can last a lifetime. StemCyte recently provided a cord blood unit that was cryopreserved for 18 years to successfully treat a 46-year-old stroke patient — demonstrating long-term viability.' },
    ],
  },
  {
    category: 'About pricing',
    items: [
      { q: 'How much does cord blood banking cost?', a: 'Cord blood processing starts at $725 with annual storage of $200/year. The 18-year prepaid plan is $3,560. Cord blood + tissue starts at $995 processing with $400/year storage. All plans include the LifeSaver Guarantee and free collection kit shipping. Public bank access is available as an Advanced Protection option.' },
      { q: 'Are payment plans available?', a: 'Yes! You can split your total into 6 or 12 monthly payments. Call (866) 389-4659 to discuss payment options with a specialist. Lifetime storage plans are also available.' },
      { q: 'Are there special programs available?', a: 'StemCyte offers special pricing for active and retired military personnel, public servants (police, fire, EMT), and medical professionals. A free Sibling Donor Program is available for families where a sibling has a diagnosis for which transplantation is standard therapy.' },
    ],
  },
  {
    category: 'About StemCyte',
    items: [
      { q: 'What makes StemCyte different from other banks?', a: "StemCyte is the only cord blood bank that operates both a private and public bank, offering families the option to add public bank access. We've shipped over 2,300 transplant units to 325+ hospitals in 40 countries — more than any other private bank. We're triple-accredited (FACT, AABB, FDA) and sponsor 3 active clinical trials." },
      { q: 'What is public bank access?', a: "Unique to StemCyte — if your child ever needs more stem cells than were stored, StemCyte will provide a matching unit from our public cord blood bank, extend the search to all global public banks, or pay up to $80,000 toward uncovered medical expenses if a matching unit is not found. Available as an Advanced Protection option with any plan." },
      { q: 'What is the LifeSaver Guarantee?', a: "If your newborn's cord blood unit fails to engraft, StemCyte will refund all service fees paid, pay an additional $50,000, and provide a replacement unit from our donor cord blood bank free of charge. This guarantee is included at no additional cost with every plan." },
      { q: "What are StemCyte's accreditations?", a: 'StemCyte is accredited by FACT (Foundation for the Accreditation of Cellular Therapy), AABB (American Association of Blood Banks), and is FDA registered. We also comply with cGMP (Current Good Manufacturing Practices). StemCyte was among the first private cord blood banks to achieve FACT accreditation.' },
    ],
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.flatMap(cat => cat.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  })))
};
---
<BaseLayout title="FAQ" schema={schema}>

<section class="hero" id="hero">
  <img src="/images/Hero_2.jpeg" alt="FAQ" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center" />
  <div class="vig"></div>
  <div class="ct">
    <div class="lbl">FAQ</div>
    <h1>Everything you need to know about cord blood banking</h1>
    <p class="sub">Answers to the most common questions from expecting parents, organized by topic.</p>
  </div>
</section>

<section class="section">
  <Accordion client:visible groups={faqData} />
  <div class="contact-box">
    <h2>Still have questions?</h2>
    <p>Our specialists are available 7 days a week to answer any questions about cord blood banking.</p>
    <div class="btns">
      <a href="tel:8663894659" class="btn-p">Call (866) 389-4659</a>
      <a href="mailto:customerservice@stemcyte.com" class="btn-s">Email us</a>
    </div>
  </div>
</section>

</BaseLayout>

<style is:global>
.hero { position:relative; min-height:540px; max-height:800px; display:flex; align-items:flex-end; overflow:hidden; }
.vig { position:absolute; inset:0; background:radial-gradient(ellipse at center,rgba(0,0,0,0.08) 0%,rgba(0,0,0,0.5) 65%,rgba(0,0,0,0.72) 100%); z-index:1; }
.ct { position:relative; z-index:2; max-width:1100px; margin:0 auto; padding:180px 48px 72px; width:100%; }
.lbl { font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#E8A0D0; margin-bottom:12px; }
.hero h1 { font-family:'Playfair Display',serif; font-size:48px; font-weight:400; line-height:1.1; letter-spacing:-1.5px; max-width:680px; margin-bottom:16px; color:#fff; }
.sub { font-size:17px; color:rgba(255,255,255,0.55); max-width:540px; line-height:1.7; }
.section { padding:80px 48px; max-width:1100px; margin:0 auto; }
.contact-box { background:#F3F0F8; border-radius:12px; padding:40px; text-align:center; margin-top:64px; }
.contact-box h3 { font-family:'Playfair Display',serif; font-size:24px; font-weight:400; margin-bottom:8px; }
.contact-box p { font-size:15px; color:#6B6760; margin-bottom:20px; }
.contact-box .btns { display:flex; gap:12px; justify-content:center; }
.btn-p { background:#6C1A55; color:#fff; padding:14px 32px; border-radius:100px; font-size:14px; font-weight:700; border:none; cursor:pointer; font-family:'Lato',sans-serif; display:inline-block; text-decoration:none; }
.btn-s { background:transparent; color:#6C1A55; padding:14px 32px; border-radius:100px; font-size:14px; font-weight:700; border:1px solid #E8E2DC; cursor:pointer; font-family:'Lato',sans-serif; display:inline-block; text-decoration:none; }
@media (max-width:900px) {
  .ct { padding:140px 24px 48px; }
  .hero h1 { font-size:34px; }
  .section { padding:64px 24px; }
  .contact-box .btns { flex-direction:column; }
}
@media (max-width:600px) {
  .hero h1 { font-size:28px; }
}
</style>
