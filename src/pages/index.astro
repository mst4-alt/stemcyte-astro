---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cord Blood Banking & Stem Cell Therapy">
  <section id="hero" style="position: relative; min-height: 80vh; display: flex; align-items: flex-end; padding: 0 48px 80px; background: linear-gradient(180deg, #3D0F31 0%, #6C1A55 100%);">
    <div style="position: relative; z-index: 2; max-width: 680px;">
      <h1 style="font-family: 'Playfair Display', serif; font-size: 52px; font-weight: 400; color: #fff; line-height: 1.08; letter-spacing: -1.5px; margin-bottom: 16px;">
        Protect your baby's future with cord blood banking
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.6); line-height: 1.7; max-width: 540px;">
        Placeholder homepage &mdash; the full site is being rebuilt in Astro.
      </p>
    </div>
  </section>

  <section style="padding: 80px 48px; max-width: 900px; margin: 0 auto;">
    <h2 style="font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 400; color: #2C2A26; margin-bottom: 16px;">Foundation verified</h2>
    <p style="font-size: 16px; color: #8A857A; line-height: 1.7;">
      Nav, Footer, fonts, global styles, schema markup, and deployment are all working. Pages will be added in subsequent batches.
    </p>
  </section>
</BaseLayout>
