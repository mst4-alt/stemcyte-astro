</style>

<script is:inline>
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('anim-visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.anim,[data-anim]').forEach(function(el) { if (!el.classList.contains('tl-item')) obs.observe(el); });

  // Scroll-linked career timeline
  (function() {
    var tl = document.getElementById('career-tl');
    if (!tl) return;
    var fill = tl.querySelector('.tl-fill');
    var items = Array.prototype.slice.call(tl.querySelectorAll('.tl-item'));
    if (!fill || !items.length) return;
    function update() {
      var rect = tl.getBoundingClientRect();
      var viewMid = window.innerHeight * 0.65;
      var scrollInto = viewMid - rect.top;
      var pct = Math.max(0, Math.min(1, scrollInto / rect.height));
      fill.style.height = (pct * 100) + '%';
      items.forEach(function(item) {
        var itemRect = item.getBoundingClientRect();
        var itemMid = itemRect.top + itemRect.height * 0.3;
        if (itemMid < viewMid) {
          item.classList.add('tl-item-visible');
          var dot = item.querySelector('[data-dot]');
          if (dot) {
            var isHighlight = item.getAttribute('data-highlight') === 'true';
            dot.className = 'tl-dot ' + (isHighlight ? 'tl-dot-highlight-reached' : 'tl-dot-reached');
          }
        }
      });
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  })();

  // Publications modal
  (function() {
    var openBtn = document.getElementById('pub-modal-open');
    var closeBtn = document.getElementById('pub-modal-close');
    var scrim = document.getElementById('pub-modal-scrim');
    var modal = document.getElementById('pub-modal');
    if (!openBtn || !modal) return;
    function open() { modal.classList.add('open'); scrim.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function close() { modal.classList.remove('open'); scrim.classList.remove('open'); document.body.style.overflow = ''; }
    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    scrim.addEventListener('click', close);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') close(); });
  })();
</script>
