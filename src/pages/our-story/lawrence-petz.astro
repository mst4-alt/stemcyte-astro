.sy-left { background:linear-gradient(135deg,#3D0F31,#6C1A55); min-height:240px; display:flex; align-items:center; justify-content:center; }
.sy-overlay { text-align:center; color:#fff; }
.sy-years { font-family:'Source Serif 4',serif; font-size:36px; font-weight:400; margin-bottom:4px; }
.sy-sub { font-size:13px; opacity:0.6; }
.sy-right { padding:32px 32px 32px 0; }
.sy-right h3 { font-size:20px; font-weight:700; margin-bottom:12px; }
.sy-right p { font-size:14px; color:#8A857A; line-height:1.7; }

/* HIV SECTION */
.hiv-section { background:#0A0508; padding:100px 48px; position:relative; overflow:hidden; }
.hiv-inner { max-width:1100px; margin:0 auto; position:relative; z-index:1; }
.hiv-grid { display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:center; }
.hiv-badge { display:inline-flex; align-items:center; gap:8px; font-size:12px; color:#E8A0D0; font-weight:600; margin-bottom:16px; }
.hiv-pdot { width:6px; height:6px; border-radius:50%; background:#E8A0D0; }
.hiv-label { font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#C06AA5; margin-bottom:10px; }
.hiv-h2 { font-family:'Playfair Display',serif; font-size:40px; font-weight:400; color:#fff; line-height:1.1; margin-bottom:16px; }
.hiv-h2 em { font-style:italic; color:#E8A0D0; }
.hiv-patient { font-size:16px; color:rgba(255,255,255,0.6); line-height:1.7; margin-bottom:12px; }
.hiv-desc { font-size:14px; color:rgba(255,255,255,0.4); line-height:1.7; margin-bottom:20px; }
