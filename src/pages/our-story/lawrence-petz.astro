      <div class="book-cover" style="background:linear-gradient(135deg,#3D0F31,#6C1A55)"><div class="book-cover-title">Clinical Bone Marrow Transplantation</div></div>
      <div class="book-title">Clinical Bone Marrow Transplantation</div>
