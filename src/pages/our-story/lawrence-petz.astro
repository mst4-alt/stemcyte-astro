<style is:global>
/* HERO */
.hero-bg { background: linear-gradient(to bottom, #E2E4E8 0%, #ECEDEF 50%, #FAF7F2 100%); }
.hero { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; min-height:600px; max-height:600px; padding:90px 48px 48px; gap:64px; }
.hero-img { overflow:hidden; border-radius:4px; background:#1A0714; aspect-ratio:4/5; max-width:75%; justify-self:end; margin-top:40px; }
.hero-portrait { width:100%; height:100%; object-fit:cover; object-position:center 20%; }
.hero-text { display:flex; flex-direction:column; justify-content:flex-end; padding:0 0 24px 0; }
