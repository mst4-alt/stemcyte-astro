  </div>
</div></section>

<div class="divider"><div class="divider-line"></div></div>

<!-- OTHER LEADERS -->
<section class="section"><div class="inner">
  <div class="sec-label">Leadership</div>
  <h2 class="sec-h2">Meet our team</h2>
  <div class="other-leaders">
    <a href="/our-story/jonas-wang" class="other-card"><img class="other-avatar" src="/images/our%20story/jonas-sm.jpg" alt="Jonas Wang, PhD" width="64" height="64" /><div class="other-info"><h3 class="other-name">Jonas Wang, PhD</h3><span>Chairman</span></div><svg class="other-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/our-story/tong-young-lee" class="other-card"><img class="other-avatar" src="/images/our%20story/lee-sm.jpg" alt="Tong-Young Lee, PhD" width="64" height="64" /><div class="other-info"><h3 class="other-name">Tong-Young Lee, PhD</h3><span>CEO</span></div><svg class="other-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/our-story/joseph-rosenthal" class="other-card"><img class="other-avatar" src="/images/our%20story/rosenthal-sm.jpg" alt="Joseph Rosenthal, MD" width="64" height="64" /><div class="other-info"><h3 class="other-name">Joseph Rosenthal, MD</h3><span>Chief Medical Officer</span></div><svg class="other-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></a>
